---
// src/layouts/BaseLayout.astro

import { pwaInfo } from "virtual:pwa-info";

import { translations } from "../i18n";

import Loader from "../components/Loader.astro";
import InstallPWA from '../components/InstallPWA.jsx';
import Navbar from "../components/Nadbar.astro";
import FondoGlobal from "../components/FondoGlobal.astro";
import Cursor from "../components/CustomCursor.astro";
import DockMenu from "../components/DockMenu.astro";
import BotGO from "../components/BotGO.jsx";

const {
  title = "Grupo Ortiz | Fabricante de Polímeros y Empaques en México",
  description = "Más de 65 años fabricando stretch film, sacos, cuerdas, rafia, arpillas y empaques flexibles. Líder en polímeros plásticos en México y Latinoamérica.",
  author = "Grupo Ortiz",
  currentLang = "es",
  moveLogoMobile = false,
  pwaIcon = "/pwa-192x192.png",
} = Astro.props;

const lang = (currentLang && currentLang in translations) ? currentLang : "es";
const t = translations[lang as keyof typeof translations] as any;
const pwaTexts = (t && t.pwa) ? t.pwa : {
  appName:     "Grupo Ortiz",
  title:       "Instalar GO App",
  description: "Acceso rápido desde tu pantalla de inicio",
  install:     "Instalar",
  notNow:      "Ahora no",
  timeLabel:   "ahora",
};
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover"
    />
    <meta name="theme-color" content="#ffffff" />

    <meta name="google-site-verification" content="rOmVFzyWzonDprnnaI7IaKK0inenxoZB4zXYCa7R5GU" />

    <!-- ✅ FIX CADENA CRÍTICA: preconnect Google Fonts antes del primer render -->
    <!-- ANTES: no había preconnect — el browser hacía DNS lookup tarde -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- ✅ FIX CADENA CRÍTICA: preload de la fuente woff2 más pesada (48 KiB, llegaba a 1,293ms) -->
    <!-- El browser la descarga en paralelo al HTML, sin esperar al CSS de Google Fonts -->
    <!-- ⚠️  Verifica que esta URL coincida exactamente con la del woff2 en tu Lighthouse -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
      href="https://fonts.gstatic.com/s/poppins/v24/pxiByp8kv8JHgFVrLCz7Z1xlFd2JQEk.woff2"
    />

    <!-- ⚡ 1. Tema aplicado PRIMERO — evita FOUC antes que cualquier otra cosa -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem("theme") === "dark")
            document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>

    <!-- ⚡ 2. Detección PWA temprana — antes de renderizar el DOM -->
    <script is:inline>
      (function () {
        try {
          const isPWA =
            window.matchMedia('(display-mode: standalone)').matches ||
            window.navigator.standalone === true ||
            document.referrer.includes('android-app://');
          document.documentElement.classList.add(isPWA ? 'is-pwa' : 'no-pwa');
        } catch (e) {}
      })();
    </script>

    <link rel="preload" href="/fonts/MorganitePro-ExtraBold.ttf"   as="font" type="font/ttf" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/MorganitePro-BoldOblique.ttf" as="font" type="font/ttf" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/NeueMontreal-Medium.otf"      as="font" type="font/otf" crossorigin="anonymous" />

    <!-- ═══════════════════════════════════════
         SEO BÁSICO
    ═══════════════════════════════════════ -->
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://grupo-ortiz.com/${currentLang}/`} />

    <!-- ═══════════════════════════════════════
         OPEN GRAPH — Facebook, WhatsApp, LinkedIn
    ═══════════════════════════════════════ -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:locale" content={currentLang === 'es' ? 'es_MX' : 'en_US'} />
    <meta property="og:site_name" content="Grupo Ortiz" />
    <meta property="og:image" content="https://grupo-ortiz.com/images/og-preview.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={`https://grupo-ortiz.com/${currentLang}/`} />

    <!-- ═══════════════════════════════════════
         TWITTER / X CARD
    ═══════════════════════════════════════ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content="https://grupo-ortiz.com/images/og-preview.jpg" />
    <meta name="twitter:site" content="@GrupoOrtiz" />

    <!-- ═══════════════════════════════════════
         ICONOS Y PWA
    ═══════════════════════════════════════ -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512x512.png" />
    <link rel="apple-touch-icon" href={pwaIcon} />

    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <slot name="head" />

    <!-- ═══════════════════════════════════════
         GOOGLE ANALYTICS — carga diferida
         ✅ FIX: eliminado del <head> para no bloquear LCP.
         Se carga tras primer scroll/clic o a los 5s máximo.
    ═══════════════════════════════════════ -->
    <script is:inline>
      (function () {
        var gtmLoaded = false;

        function loadGTM() {
          if (gtmLoaded) return;
          gtmLoaded = true;

          window['dataLayer'] = window['dataLayer'] || [];
          function gtag() { window['dataLayer'].push(arguments); }
          window['gtag'] = gtag;
          gtag('js', new Date());
          gtag('config', 'G-XZJL55JDPH');

          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-XZJL55JDPH';
          document.head.appendChild(s);
        }

        // Carga tras primer scroll, clic o tecla — lo que ocurra primero
        ['scroll', 'click', 'touchstart', 'keydown'].forEach(function (evt) {
          window.addEventListener(evt, loadGTM, { once: true, passive: true });
        });

        // Fallback: cargar a los 5s aunque no haya interacción
        setTimeout(loadGTM, 5000);
      })();
    </script>

    <style is:global>
      @import "../styles/typography.css";
      @import "../styles/backgrounds.css";

      #loader-wrapper {
        transition: opacity 0.4s ease;
      }

      .home-curtain {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 99999;
        pointer-events: none;
        background: var(--slide-gradient);
        clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
      }

      .home-curtain.active {
        pointer-events: all;
        animation: 2.2s cubic-bezier(0.25, 1, 0.3, 1) wipe-in-top-down both;
      }

      @keyframes wipe-in-top-down {
        from { clip-path: polygon(0 0, 100% 0, 100% 0, 0 0); }
        to   { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
      }

      #dock-menu-wrapper {
        display: none;
      }

      html.is-pwa #dock-menu-wrapper {
        display: block;
      }

      @media all and (display-mode: standalone) {
        #dock-menu-wrapper {
          display: block !important;
        }
      }

      #admin-panel-root {
        pointer-events: none;
      }
      #admin-panel-root > * {
        pointer-events: auto;
      }

      * {
        -webkit-tap-highlight-color: transparent;
      }

      html, body {
        touch-action: pan-x pan-y;
      }

      a,
      button,
      [role="button"],
      label,
      input[type="button"],
      input[type="submit"],
      input[type="reset"],
      select,
      summary {
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
        outline: none;
        touch-action: pan-x pan-y;
      }

      section,
      article,
      .card,
      .btn,
      [class*="container"],
      [class*="wrapper"],
      [class*="section"],
      [class*="block"],
      [class*="tile"],
      [class*="item"],
      [class*="box"],
      nav,
      header,
      footer,
      aside {
        -webkit-user-select: none;
        -moz-user-select: none;
        user-select: none;
      }

      p,
      span,
      h1, h2, h3, h4, h5, h6,
      input[type="text"],
      input[type="email"],
      input[type="password"],
      input[type="search"],
      input[type="number"],
      textarea {
        -webkit-user-select: text;
        -moz-user-select: text;
        user-select: text;
      }
    </style>

  </head>

  <body>
    <!-- ✅ FIX: ContentSquare con defer — no bloquea el render inicial -->
    <!-- ANTES: <script src="https://t.contentsquare.net/uxa/3fd14649ff498.js"></script> -->
    <script defer src="https://t.contentsquare.net/uxa/3fd14649ff498.js"></script>

    <div id="home-transition-curtain" class="home-curtain"></div>
    <FondoGlobal />

    <InstallPWA pwa={pwaTexts} client:idle />

    <Cursor />
    <Loader />
    <Navbar currentLang={currentLang} moveLogoMobile={moveLogoMobile} />

    <div
      id="global-audio-player"
      transition:persist
      style="position: fixed; bottom: 30px; right: 96px; z-index: 9999;"
    >
    </div>

    <slot />

    <div id="dock-menu-wrapper">
      <DockMenu />
    </div>

    <!-- ✅ BotGO ya tiene client:idle — correcto, no tocar -->
    <BotGO client:idle language={currentLang} />

    <div id="admin-panel-root"></div>

    <script src="/scripts/theme-toggle.js" defer></script>

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          import('virtual:pwa-register').then(({ registerSW }) => {
            registerSW({ immediate: false });
          });
        });
      }
    </script>

    <script is:inline>
      (function () {
        function hideLoader() {
          requestAnimationFrame(function () {
            var loader = document.getElementById("loader-wrapper");
            if (!loader) return;
            loader.style.opacity = "0";
            setTimeout(function () {
              loader.style.display = "none";
            }, 400);
          });
        }

        if (document.readyState === "complete") {
          hideLoader();
        } else {
          window.addEventListener("load", hideLoader, { once: true });
        }
      })();
    </script>

    <script>
      let adminMounted = false;

      document.addEventListener("keydown", async (e) => {
        if (!e.ctrlKey || e.key !== "9") return;
        e.preventDefault();

        const root = document.getElementById("admin-panel-root");
        if (!root || adminMounted) return;

        adminMounted = true;

        try {
          const [{ default: React }, { createRoot }, { default: AdminPanel }] =
            await Promise.all([
              import("react"),
              import("react-dom/client"),
              import("../components/AdminPanel.jsx"),
            ]);

          root.style.pointerEvents = "none";

          const reactRoot = createRoot(root);
          reactRoot.render(
            React.createElement(AdminPanel, { defaultOpen: true })
          );
        } catch (err) {
          console.error("[AdminPanel] Error al cargar:", err);
          adminMounted = false;
        }
      });
    </script>
  </body>
</html>