---
// VideoWithFallback.astro
// Fuente 1: Cloudinary (q_auto:best). Fuente 2: local. Fuente 3: imagen poster como último recurso.

interface Props {
  cloudinaryId: string;
  localFallback: string;
  cloudName?: string;
  poster?: string;
  autoplay?: boolean;
  muted?: boolean;
  loop?: boolean;
  playsinline?: boolean;
  controls?: boolean;
  class?: string;
  id?: string;
  preload?: "auto" | "metadata" | "none";
  productName?: string;
}

const {
  cloudinaryId,
  cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME ?? "dfuzfdrat",
  localFallback,
  poster,
  autoplay = false,
  muted = true,
  loop = false,
  playsinline = true,
  controls = false,
  class: className,
  id,
  preload = "metadata",
  productName,
} = Astro.props;

// q_auto:best = máxima calidad sin comprimir de más
// fl_faststart = permite reproducción progresiva antes de descarga completa
const cldSrc = cloudinaryId
  ? `https://res.cloudinary.com/${cloudName}/video/upload/q_auto:best/${cloudinaryId}.mp4`
  : null;
---

<video
  id={id}
  class={className}
  autoplay={autoplay}
  muted={muted}
  loop={loop}
  playsinline={playsinline}
  controls={controls}
  preload={preload}
  data-fallback={localFallback}
  data-poster={poster}
  data-product={productName}
>
  {cldSrc && <source src={cldSrc} type="video/mp4" />}
  <source src={localFallback} type="video/mp4" />
</video>

<script>
  function attachFallback(video: HTMLVideoElement) {
    // Evitar registrar el listener más de una vez por elemento
    if ((video as any).__fallbackAttached) return;
    (video as any).__fallbackAttached = true;

    const local = video.dataset.fallback;
    const posterSrc = video.dataset.poster;
    if (!local) return;

    let triedLocal = false;

    function showImageFallback() {
      if (!posterSrc) return;
      const img = document.createElement('img');
      img.src = posterSrc;
      img.alt = '';
      img.setAttribute('aria-hidden', 'true');
      img.className = video.className;
      img.style.cssText = video.style.cssText;
      img.style.objectFit = 'cover';
      video.parentElement?.insertBefore(img, video);
      video.style.display = 'none';
    }

    function switchToLocal() {
      if (triedLocal) { showImageFallback(); return; }
      triedLocal = true;
      // Verificar que el local no esté ya en uso (currentSrc es URL absoluta)
      const currentSrc = video.currentSrc || '';
      if (currentSrc && (currentSrc.endsWith(local) || currentSrc.includes(local))) return;
      video.src = local;
      video.load();
      if (video.autoplay) video.play().catch(showImageFallback);
    }

    // Solo activa fallback en error real (404, red caída, codec no soportado)
    video.addEventListener('error', switchToLocal, true);
  }

  function initFallbacks() {
    document.querySelectorAll<HTMLVideoElement>('video[data-fallback]').forEach(attachFallback);
  }

  document.addEventListener('DOMContentLoaded', initFallbacks);
  document.addEventListener('astro:page-load', initFallbacks);
</script>
