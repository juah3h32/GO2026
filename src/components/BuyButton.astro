---
const { 
  text = "Cotizar por WhatsApp", 
  redirecting = "Abriendo WhatsApp...",
  whatsappNumber = "5214432072593"
} = Astro.props;
---

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

<button id="truck-cta-btn" class="cta-btn" data-whatsapp={whatsappNumber}>
  <span class="default">{text}</span>
  <span class="success">
    {redirecting}
    <svg viewBox="0 0 12 10"><polyline points="1.5 6 4.5 9 10.5 1"></polyline></svg>
  </span>
  <div class="truck">
    <div class="wheel"></div>
    <div class="back">
      <img src="/images/logoN.png" alt="Logo Grupo Ortiz" class="truck-logo" />
    </div>
    <div class="front"></div>
    <div class="box"></div>
  </div>
</button>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("truck-cta-btn");
    if (!button) return;
    const truck = button.querySelector(".truck");
    const box = button.querySelector(".box");
    if (!truck || !box) return;

    const resetBtn = () => {
      button.classList.remove("animation", "done");
      gsap.set(truck, { x: -90, opacity: 0 });
      gsap.set(button, { "--progress": 0, "--hx": 0, "--bx": 0, "--box-s": 0.5, "--box-o": 0 });
      gsap.set(box, { x: -24, y: -6 });
    };

    const getActiveProductData = () => {
      const activeThumb = document.querySelector(".thumb-item.active");
      if (!activeThumb) return null;
      const productIndex = parseInt(activeThumb.dataset.index || "0");
      const mainContainer = document.querySelector(".main-container");
      if (!mainContainer) return null;
      const productsData = JSON.parse(mainContainer.dataset.products || "[]");
      const product = productsData[productIndex];
      if (!product) return null;
      return {
        name: product.name || "Producto",
        description: product.description || "",
        specs: product.specs_values
          ? {
              load: product.specs_values.load || "",
              unit: product.specs_values.unit || "",
              material: product.specs_values.mat || "",
              weight: product.specs_values.weight || "",
              resistance: product.specs_values.resist || "",
              charge: product.specs_values.charge || "",
            }
          : null,
      };
    };

    const buildWhatsAppMessage = (productData) => {
      if (!productData) return encodeURIComponent("Hola! Me interesa cotizar sus productos.");
      let message = "Hola! Me interesa cotizar el siguiente producto:\n\n";
      message += `📦 *${productData.name}*\n`;
      if (productData.description) message += `${productData.description}\n`;
      if (productData.specs) {
        message += "\n*Especificaciones:*\n";
        if (productData.specs.load)       message += `• Carga: ${productData.specs.load}\n`;
        if (productData.specs.unit)       message += `• Unidad: ${productData.specs.unit}\n`;
        if (productData.specs.material)   message += `• Material: ${productData.specs.material}\n`;
        if (productData.specs.weight)     message += `• Peso: ${productData.specs.weight}\n`;
        if (productData.specs.resistance) message += `• Resistencia: ${productData.specs.resistance}\n`;
        if (productData.specs.charge)     message += `• Capacidad: ${productData.specs.charge}\n`;
      }
      message += "\n¿Podrían proporcionarme más información y precio?";
      return encodeURIComponent(message);
    };

    button.addEventListener("click", (e) => {
      e.preventDefault();
      const whatsappNumber = button.dataset.whatsapp || "5214431234567";
      const productData = getActiveProductData();

      if (!button.classList.contains("done") && !button.classList.contains("animation")) {
        button.classList.add("animation");

        gsap.to(truck, { x: 4, opacity: 1, duration: 0.4, ease: "power2.out" });
        gsap.to(button, { "--box-s": 1, "--box-o": 1, duration: 0.3, delay: 0.5 });
        gsap.to(box, { x: 0, duration: 0.4, delay: 0.7 });
        gsap.to(button, { "--hx": -5, "--bx": 50, duration: 0.18, delay: 0.92 });
        gsap.to(box, { y: 0, duration: 0.1, delay: 1.15 });

        gsap.to(truck, {
          y: -2,
          duration: 0.2,
          delay: 1.25,
          onComplete() {
            gsap.to(truck, { y: 0, duration: 0.1 });
            gsap.timeline({
              onComplete() {
                button.classList.add("done");
                setTimeout(() => {
                  const message = buildWhatsAppMessage(productData);
                  window.open(`https://wa.me/${whatsappNumber}?text=${message}`, "_blank");
                  setTimeout(() => { resetBtn(); }, 1000);
                }, 500);
              },
            })
              .to(truck, { x: 0, duration: 0.4 })
              .to(truck, { x: 40, duration: 1 })
              .to(truck, { x: 20, duration: 0.6 })
              .to(truck, { x: 240, duration: 0.4 });

            gsap.to(button, { "--progress": 1, duration: 2.4, ease: "power2.in" });
          },
        });
      }
    });
  });
</script>

<style>
  .cta-btn {
    --background: #fb670b;
    --street-fill: #b34606;
    --tick: #16bf78;
    --wheel: #555;
    --wheel-inner: #999;
    --truck-body: #ffffff;
    --truck-body-shadow: #dddddd;
    --window: #a8d4f5;
    --bumper: #cccccc;
    --box: #dcb97a;
    --box-shadow: #b89b66;

    padding: 12px 0;
    width: 220px;
    cursor: pointer;
    text-align: center;
    position: relative;
    border: none;
    outline: none;
    color: #ffffff !important;
    background: var(--background);
    border-radius: 15px;
    appearance: none;
    -webkit-appearance: none;
    -webkit-tap-highlight-color: transparent;
    overflow: hidden;
    margin-top: 20px;
    box-shadow: 0 10px 20px -8px rgba(251, 103, 11, 0.5);
  }

  .cta-btn:after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    height: 3px;
    width: calc(var(--progress, 0) * 100%);
    background: var(--street-fill);
    pointer-events: none;
    z-index: 1;
  }

  .cta-btn .default,
  .cta-btn .success {
    display: block;
    font-weight: 700;
    font-size: 14px;
    line-height: 24px;
    opacity: var(--o, 1);
    transition: opacity 0.3s;
    color: #ffffff !important;
    position: relative;
    z-index: 10;
  }

  .cta-btn .success {
    --o: 0;
    position: absolute;
    top: 12px;
    left: 0;
    right: 0;
  }

  .cta-btn.animation .default { --o: 0; }
  .cta-btn.animation.done .success { --o: 1; }

  .cta-btn .success svg {
    width: 12px;
    height: 10px;
    display: inline-block;
    vertical-align: top;
    fill: none;
    margin: 7px 0 0 12px;
    stroke: var(--tick);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 16px;
    stroke-dashoffset: var(--offset, 16px);
    transition: stroke-dashoffset 0.4s ease 0.45s;
  }

  .cta-btn .truck {
    position: absolute;
    width: 80px;
    height: 26px;
    bottom: 5px;
    left: 4px;
    transform: translateX(-90px);
    opacity: 0;
    z-index: 5;
    pointer-events: none;
  }

  .cta-btn .truck:before,
  .cta-btn .truck:after {
    content: "";
    position: absolute;
    bottom: -4px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    z-index: 1;
    box-shadow: inset 0 0 0 2px #333, inset 0 0 0 3px #777;
    background: #444;
  }

  .cta-btn .truck:before { left: 5px; }
  .cta-btn .truck:after  { left: 48px; }

  .cta-btn .truck .wheel { display: none; }

  .cta-btn .truck .front,
  .cta-btn .truck .back,
  .cta-btn .truck .box { position: absolute; }

  .cta-btn .truck .back {
    left: 0;
    bottom: 0;
    z-index: 3;
    width: 50px;
    height: 26px;
    border-radius: 2px;
    background: var(--truck-body);
    border: 1px solid #fb670b;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta-btn .truck .back .truck-logo {
    width: 22px;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .cta-btn .truck .back:before {
    content: "";
    position: absolute;
    right: -2px;
    top: 2px;
    width: 3px;
    height: 12px;
    background: var(--truck-body-shadow);
    border-radius: 0 2px 2px 0;
  }

  .cta-btn .truck .back:after {
    content: "";
    position: absolute;
    left: 10px;
    right: 4px;
    bottom: -2px;
    height: 3px;
    background: var(--bumper);
    border-radius: 2px;
  }

  .cta-btn .truck .front {
    left: 52px;
    bottom: 0;
    height: 26px;
    width: 22px;
    background: var(--truck-body);
    border: 1px solid #fb670b;
    border-radius: 3px 4px 3px 3px;
    z-index: 3;
  }

  .cta-btn .truck .front:before {
    content: "";
    position: absolute;
    width: 13px;
    height: 9px;
    background: var(--window);
    right: 2px;
    top: 3px;
    border-radius: 2px 5px 2px 2px;
  }

  .cta-btn .truck .front:after {
    content: "";
    position: absolute;
    width: 3px;
    height: 9px;
    right: 0;
    bottom: 3px;
    background: var(--truck-body-shadow);
    border-radius: 1px 0 0 1px;
  }

  .cta-btn .truck .box {
    width: 12px;
    height: 12px;
    right: 60px;
    bottom: 0;
    z-index: 0;
    border-radius: 1px;
    overflow: hidden;
    transform: translate(calc(var(--box-x, -24) * 1px), calc(var(--box-y, -6) * 1px)) scale(var(--box-s, 0.5));
    opacity: var(--box-o, 0);
    background: linear-gradient(68deg, var(--box) 0%, var(--box) 50%, var(--box-shadow) 50.2%, var(--box-shadow) 100%);
    background-size: 250% 100%;
    background-position-x: calc(var(--bx, 0) * 1%);
  }

  .cta-btn .truck .box:before {
    content: "";
    position: absolute;
    background: rgba(255, 255, 255, 0.2);
    left: 0;
    right: 0;
    top: 5px;
    height: 1px;
  }

  .cta-btn .truck .box:after {
    content: "";
    position: absolute;
    width: 5px;
    left: 100%;
    top: 0;
    bottom: 0;
    background: #d0d0d0;
    transform: translateX(calc(var(--hx, 0) * 1px));
  }
</style>