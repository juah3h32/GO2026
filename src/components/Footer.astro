---
// src/components/Footer.astro
import "../styles/footer.css"; 
import { translations } from "../i18n";

interface Props {
  currentLang?: string;
}

const { currentLang = 'es' } = Astro.props;
const t = translations[currentLang as keyof typeof translations] || translations.es;

const getLink = (slug: string) => {
  return currentLang === 'es' ? `/${slug}` : `/${currentLang}/${slug}`;
};
---

<footer class="minimal-footer">
  <div class="footer-container">
    
    <div class="top-section">
      
<div class="brand-area">
  <h2 class="logo">GRUPO ORTIZ&reg;</h2>

  <div class="contact-columns">
    
    <!-- Columna México -->
    <div class="contact-col">
      <span class="contact-region">{t.footer.region_mexico}</span>
      <a href={`mailto:${t.footer.email}`} class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        {t.footer.email}
      </a>
      <a href="tel:+524432072593" class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {t.footer.phone_mx}
      </a>
    </div>

    <!-- Columna EE.UU. -->
    <div class="contact-col">
      <span class="contact-region">{t.footer.region_usa}</span>
      <a href="tel:+12104293789" class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {t.footer.phone_us}
      </a>

      <span class="contact-region" style="margin-top: 10px;">{t.footer.label_warehouse}</span>
      <span class="contact-address">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {t.footer.address_warehouse}
      </span>

      <span class="contact-region" style="margin-top: 10px;">{t.footer.label_office}</span>
      <span class="contact-address">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {t.footer.address_office}
      </span>
    </div>

  </div>
</div>

      <div class="links-area">
        
        <div class="col">
          <a href="#">{t.footer.about_us}</a>
          <a href="about">{t.footer.about}</a>
          <a href="social">{t.footer.social_impact}</a>
        </div>

        <div class="col">
          <a href="#">{t.footer.customer_service}</a>
          <a href="distribuidor">{t.footer.be_distributor}</a>
          <a href="catalogo">{t.footer.catalog}</a>
        </div>

        <div class="col distribute-col">
          <a href="distribuidor" class="btn-orange">{t.footer.cta_button}</a>
        </div>

      </div>
    </div>

    <div class="separator-line"></div>

    <div class="bottom-section">
      <div class="social-icons">

        <!-- Facebook -->
        <a href="https://www.facebook.com/people/Grupo-Ort%C3%ADz/61559817857366/" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>

        <!-- Instagram -->
        <a href="https://www.instagram.com/grupoortiz_mexico?igsh=dWJtbHhrN3A2d254" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/company/grupo-ortiz-mexico-pol%C3%ADmeros/" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>

        <!-- YouTube -->
       <!-- YouTube -->
<a href="#" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
    <path d="M23 7s-.3-2-1.2-2.8c-1.1-1.2-2.4-1.2-3-1.3C16.4 2.8 12 2.8 12 2.8s-4.4 0-6.8.2c-.6.1-1.9.1-3 1.3C1.3 5 1 7 1 7S.7 9.1.7 11.3v2c0 2.1.3 4.3.3 4.3s.3 2 1.2 2.8c1.1 1.2 2.6 1.1 3.3 1.2C7.6 21.9 12 22 12 22s4.4 0 6.8-.3c.6-.1 1.9-.1 3-1.3.9-.8 1.2-2.8 1.2-2.8s.3-2.1.3-4.3v-2C23.3 9.1 23 7 23 7zM9.7 15.5V8.3l8.1 3.6-8.1 3.6z"/>
  </svg>
</a>

      </div>
      <p class="copyright">
        &copy; {new Date().getFullYear()} Grupo Ortiz, SA. de CV. {t.footer.rights}
      </p>
    </div>
  </div>
</footer>