---
// src/components/Footer.astro
import "../styles/footer.css"; 
import { translations } from "../i18n";

interface Props {
  currentLang?: string;
}

const { currentLang = 'es' } = Astro.props;
const t = translations[currentLang as keyof typeof translations] || translations.es;

const getLink = (slug: string) => {
  return currentLang === 'es' ? `/${slug}` : `/${currentLang}/${slug}`;
};
---
<link rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css'>

<footer class="minimal-footer">
<div class="footer-container">
    
    <div class="top-section">
      
      <div class="brand-area">
        <h2 class="logo">GRUPO ORTIZ&reg;</h2>
        
        <div class="brand-contact">
          <a href="mailto:contacto@grupoortiz.com" class="contact-item">
            <i class="fas fa-envelope"></i> atencionacliente@grupo-ortiz.com
          </a>
          <a href="tel:+525512345678" class="contact-item">
            <i class="fas fa-phone-alt"></i> +52 44-32-07-25-93
          </a>
        </div>
      </div>

      <div class="links-area">
        
        <div class="col">
          <a href="about">{t.footer.about_us}</a>
          <a href="about">{t.footer.about}</a>
          <a href="social">{t.footer.social_impact}</a>
        </div>

        <div class="col">
          <a href="customer-service">{t.footer.customer_service}</a>
          <a href="distribuidor">{t.footer.be_distributor}</a>
          <a href="catalogo">{t.footer.catalog}</a>
        </div>

        <div class="col distribute-col">
          <a href="distribuidor" class="btn-orange">{t.footer.cta_button}</a>
        </div>

      </div>
    </div>

    <div class="separator-line"></div>

    <div class="bottom-section">
      <div class="social-icons">
        <!-- ✅ aria-label agregado a cada red social -->
        <a href="https://www.facebook.com/people/Grupo-Ort%C3%ADz/61559817857366/"
           aria-label="Visitar Grupo Ortiz en Facebook"
           target="_blank" rel="noopener noreferrer">
          <i class="fab fa-facebook-f"></i>
        </a>
        <a href="https://www.instagram.com/grupoortiz_mexico?igsh=dWJtbHhrN3A2d254"
           aria-label="Visitar Grupo Ortiz en Instagram"
           target="_blank" rel="noopener noreferrer">
          <i class="fab fa-instagram"></i>
        </a>
        <a href="https://www.linkedin.com/company/grupo-ortiz-mexico-pol%C3%ADmeros/"
           aria-label="Visitar Grupo Ortiz en LinkedIn"
           target="_blank" rel="noopener noreferrer">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="#" aria-label="Visitar Grupo Ortiz en YouTube">
          <i class="fab fa-youtube"></i>
        </a>
      </div>
      <p class="copyright">
        &copy; {new Date().getFullYear()} Grupo Ortiz, SA. de CV. {t.footer.rights}
      </p>
    </div>
  </div>
</footer>