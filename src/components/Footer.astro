---
// src/components/Footer.astro
import "../styles/footer.css"; 
import { translations } from "../i18n"; // Asegúrate que la ruta a i18n sea correcta

interface Props {
  currentLang?: string;
}

// 1. Lógica para obtener el idioma y las traducciones
const { currentLang = 'es' } = Astro.props;
const t = translations[currentLang as keyof typeof translations] || translations.es;

// 2. Función helper para los links (opcional, para mantener el idioma en la URL)
// Ejemplo: si estás en inglés, devuelve "/en/slug"
const getLink = (slug: string) => {
  return currentLang === 'es' ? `/${slug}` : `/${currentLang}/${slug}`;
};
---
