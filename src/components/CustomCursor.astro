<div class="custom-cursor">
  <div class="cursor-dot"></div>
  <div class="ring ring-outer"></div>
  <div class="ring ring-middle"></div>
  <div class="ring ring-inner"></div>
</div>

<style>
:root {
  --tech-orange: #ff9100;
  --tech-orange-glow: rgba(255, 145, 0, 0.5);
  --dot-size: 8px;
  --cursor-size: 60px;
}


/* 1. Lógica base: El cursor nativo se oculta solo si NO es táctil */
@media (hover: hover) and (pointer: fine) {
    body, * {
        cursor: none !important; /* Fuerza ocultar el cursor nativo incluso en botones */
    }
}

.custom-cursor {
  position: fixed;
  top: 0;
  left: 0;
  pointer-events: none;
  width: var(--cursor-size);
  height: var(--cursor-size);
  display: flex;
  justify-content: center;
  align-items: center;
  transform: translate(-50%, -50%);
  z-index: 9999999; /* <--- Número exageradamente alto para que gane siempre */
}

/* 2. Lógica de ocultación para móviles/tablets */
@media (hover: none), (pointer: coarse) {
    .custom-cursor {
        display: none !important;
        opacity: 0 !important;
        visibility: hidden !important;
    }
    body {
        cursor: auto !important;
    }
}

/* Estilos de los anillos y puntos */
.cursor-dot {
  position: absolute;
  width: var(--dot-size);
  height: var(--dot-size);
  background: var(--tech-orange);
  border-radius: 50%;
  z-index: 10;
  box-shadow: 0 0 8px var(--tech-orange-glow);
}

.ring {
  position: absolute;
  border-radius: 50%;
  border: 2px solid transparent;
}

.ring-outer {
  width: 100%;
  height: 100%;
  border-top: 3px solid var(--tech-orange);
  border-bottom: 3px solid var(--tech-orange);
  opacity: 0.8;
  box-shadow: 0 0 15px var(--tech-orange-glow);
  /* Animación eliminada */
}

.ring-middle {
  width: 85%;
  height: 85%;
  border-left: 2px solid #fff;
  border-right: 2px solid #fff;
  opacity: 0.3;
  /* Animación eliminada */
}

.ring-inner {
  width: 70%;
  height: 70%;
  border: 1px dashed var(--tech-orange);
  opacity: 0.5;
  /* Animación eliminada */
}

/* Se eliminaron los @keyframes spin y spin-reverse */
</style>

<script is:inline>
// DETECCIÓN ROBUSTA DE MÓVIL
const isTouch = (('ontouchstart' in window) || (navigator.maxTouchPoints > 0));

const cursor = document.querySelector('.custom-cursor');

if (isTouch) {
    if(cursor) cursor.remove();
} else {
    const cursorDot = document.querySelector('.cursor-dot');
    let mouseX = 0, mouseY = 0;
    let posX = 0, posY = 0;
    
    // Si quieres que el movimiento sea instantáneo (sin retraso), cambia delay a 1
    // Si quieres mantener el efecto suave, déjalo en 0.19
    const delay = 0.19;

    document.addEventListener('mousemove', e => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    function animateCursor() {
      posX += (mouseX - posX) * delay;
      posY += (mouseY - posY) * delay;
      
      if (cursor) {
        cursor.style.transform = `translate(${posX}px, ${posY}px) translate(-50%, -50%)`;
        requestAnimationFrame(animateCursor);
      }
    }
    
    animateCursor();
}
</script>