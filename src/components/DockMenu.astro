---
/* src/components/DockMenu.astro */
const currentPath = Astro.url.pathname;
const lang = currentPath.split('/')[1] || 'es';

const isProducts = currentPath.includes('productos');
const isHome = currentPath === '/' || currentPath === `/${lang}` || currentPath === `/${lang}/`;
const isImpacto = currentPath.includes('social');
const isDistribuidor = currentPath.includes('distribuidor');
const isAbout = currentPath.includes('about');
const isCatalogo = currentPath.includes('catalogo');

const rutasOcultas = ['cuerdas','sacos','rafias','arpillas','esquineros','stretch-film','empaques-flexibles'];
const debeOcultarse = rutasOcultas.some(ruta => currentPath.includes(ruta));

const mostrarRegresar = !isHome && !isImpacto && !isDistribuidor && !isAbout && !isCatalogo;
---

{ !debeOcultarse && (

<nav class="dock-wrapper" id="dock-menu">
  <div class="glass-dock">

    <!-- Inicio -->
    <a href={`/${lang}`} class={`dock-item ${isHome ? 'active' : ''}`} aria-label="Inicio">
      <div class="icon-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
      </div>
      <span class="dot"></span>
    </a>

    <!-- Productos -->
    <a href={`/${lang}/productos`} class={`dock-item ${isProducts ? 'active' : ''}`} aria-label="Productos">
      <div class="icon-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
      </div>
      <span class="dot"></span>
    </a>

    <!-- WhatsApp -->
    <a href="https://wa.me/524432072593" target="_blank" class="dock-item" aria-label="WhatsApp">
      <div class="icon-box whatsapp-highlight">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
      </div>
    </a>

    <!-- Impacto Social (inicio o página social) -->
    {(isHome || isImpacto) && (
      <a href={`/${lang}/social`} class={`dock-item ${isImpacto ? 'active' : ''}`} aria-label="Impacto Social">
        <div class="icon-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 8C8 10 5.9 16.17 3.82 19.9c-.38.66.22 1.42.88 1.17C6.17 20.32 8.5 19 12 19c6 0 9-4 9-9 0-1-.5-3-4-2z"/>
            <path d="M3 22c0-5 2-10 7-13"/>
          </svg>
        </div>
        <span class="dot"></span>
      </a>
    )}

    <!-- Distribuidor: corazón -->
    {isDistribuidor && (
      <a href={`/${lang}/ser-distribuidor`} class="dock-item active" aria-label="Distribuidor">
        <div class="icon-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
        <span class="dot"></span>
      </a>
    )}

    <!-- Nosotros: fábrica -->
    {isAbout && (
      <a href={`/${lang}/about`} class="dock-item active" aria-label="Nosotros">
        <div class="icon-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="1"></rect>
            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"></path>
            <line x1="12" y1="12" x2="12" y2="12"></line>
            <path d="M2 12h8"></path>
            <path d="M14 12h8"></path>
          </svg>
        </div>
        <span class="dot"></span>
      </a>
    )}

    <!-- Catálogo: libro abierto -->
    {isCatalogo && (
      <a href={`/${lang}/catalogo`} class="dock-item active" aria-label="Catálogo">
        <div class="icon-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </div>
        <span class="dot"></span>
      </a>
    )}

    <!-- Regresar: otras páginas -->
    {mostrarRegresar && (
      <a href="javascript:void(0)" onclick="goBack()" class="dock-item" aria-label="Regresar">
        <div class="icon-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path></svg>
        </div>
      </a>
    )}

  </div>
</nav>

)}

<style>
  :root {
    --dock-bg: rgba(255, 255, 255, 0.85);
    --dock-border: rgba(255, 255, 255, 0.6);
    --primary-color: #F05537;
    --text-inactive: #A0A0A0;
    --shadow-soft: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .dock-wrapper { display: none; }

  @media screen and (max-width: 1024px) {
    .dock-wrapper {
      display: flex;
      justify-content: center;
      position: fixed;
      bottom: 20px;
      left: 0;
      width: 100%;
      z-index: 2000;
      pointer-events: none;
      padding-bottom: env(safe-area-inset-bottom);
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .dock-wrapper.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .glass-dock {
      pointer-events: auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      width: 92%;
      height: 70px;
      background: var(--dock-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--dock-border);
      border-radius: 24px;
      box-shadow: var(--shadow-soft);
      align-items: center;
      justify-items: center;
      padding: 0 10px;
    }

    .dock-item {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      text-decoration: none;
      color: var(--text-inactive);
      -webkit-tap-highlight-color: transparent;
      transition: transform 0.1s ease;
    }

    .dock-item:active { transform: scale(0.9); }

    .icon-box {
      position: relative;
      width: 42px;
      height: 42px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      z-index: 2;
    }

    .dock-item svg {
      width: 24px;
      height: 24px;
      stroke-width: 2px;
      transition: all 0.3s ease;
    }

    .dock-item.active .icon-box {
      background: var(--primary-color);
      color: white;
      transform: translateY(-25px) scale(1.15);
      box-shadow: 0 8px 20px rgba(240, 85, 55, 0.4);
      border-radius: 50%;
      outline: 6px solid rgba(255, 255, 255, 0.85);
    }

    .dot {
      position: absolute;
      bottom: 8px;
      width: 4px;
      height: 4px;
      background-color: var(--primary-color);
      border-radius: 50%;
      opacity: 0;
      transform: scale(0);
      transition: all 0.3s ease;
    }

    .dock-item.active .dot {
      opacity: 1;
      transform: scale(1);
      bottom: 12px;
    }

    .dock-item:hover .whatsapp-highlight { color: #25D366; }
  }
</style>

<script>
  function goBack() {
    if (window.history.length > 1) {
      window.history.back();
    } else {
      const lang = window.location.pathname.split('/')[1] || 'es';
      window.location.href = `/${lang}`;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const dock = document.getElementById('dock-menu');
    if (!dock) return;

    const isProducts = window.location.pathname.includes('productos');

    // Leer clase puesta por el BaseLayout en el <html>
    const isPWA = document.documentElement.classList.contains('is-pwa');

    if (!isPWA) {
      document.body.classList.add('no-pwa');
    }

    if (isProducts) {
      dock.classList.add('visible');
    } else {
      let lastScroll = 0;
      let timeout: ReturnType<typeof setTimeout>;

      window.addEventListener('scroll', () => {
        const current = window.scrollY;
        if (current < 80) { dock.classList.remove('visible'); return; }
        if (current > lastScroll) { dock.classList.add('visible'); }
        else { dock.classList.remove('visible'); }
        lastScroll = current;
        clearTimeout(timeout);
        timeout = setTimeout(() => { dock.classList.remove('visible'); }, 1500);
      }, { passive: true });
    }
  });
</script>