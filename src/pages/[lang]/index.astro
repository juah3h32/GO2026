---
/* ============================================================================
   HOME PAGE - INDEX (CON TRADUCCIONES i18n)
   ============================================================================ */
import "../../styles/home.css";
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import { languages, translations } from '../../i18n';
import HeroHeadingTypewriter from '../../components/HeroHeadingTypewriter.tsx';
import StickySection from '../../components/StickySection.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const currentLang = (lang && lang in translations) ? lang : 'es';
const t  = translations[currentLang as keyof typeof translations];
const th = t.home as typeof translations['es']['home'];

const certifications = th.certs.items;
const certsLoop = [...certifications, ...certifications];

const divItems = th.divisiones.items;
const divLoop  = [...divItems, ...divItems];

/* ── Typewriter hero words (localizados) ── */
const tyPrefix   = (th.hero as any).typewriter_prefix as string ?? ""
const tyGeoWord  = tyPrefix
  ? th.hero.title_bot.slice(tyPrefix.length).trim()
  : th.hero.title_bot
const tyWords    = [
  tyGeoWord.toUpperCase(),
  ...th.divisiones.items
    .filter((d: any) => !d.soon)
    .map((d: any) => (d.title as string).toUpperCase()),
]

/* ── Cloud name para posters ── */
const CLOUD = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const poster = (src: string) =>
  `https://res.cloudinary.com/${CLOUD}/video/upload/f_jpg,q_auto,so_0/${src}.jpg`;
---

<BaseLayout
  title={th.meta_title}
  description={th.meta_description}
  currentLang={currentLang}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={poster(th.hero.video)} fetchpriority="high" />
  </Fragment>

<!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
<section class="hero hero--static">
  <!-- Video hero de fondo —— Cloudinary URL directa, sin SDK -->
  <div class="hero__video-wrap" data-fallback-wrap>
    <video
      id="hero-video"
      class="hero__video hero__video--fill"
      src={`https://res.cloudinary.com/${CLOUD}/video/upload/q_auto:best/${th.hero.video}.mp4`}
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={poster(th.hero.video)}
    ></video>
    <!-- Fallback local: se muestra solo si Cloudinary falla -->
    <video
      class="hero__video hero__video--fill"
      src={`/videos/${th.hero.video.replace(/^GO\//, '')}.mp4`}
      autoplay
      muted
      loop
      playsinline
      poster={poster(th.hero.video)}
      data-role="fallback"
      style="display:none;"
    ></video>
  </div>

  <div class="hero__gradient-overlay"></div>
  <div class="hero__eco-overlay" aria-hidden="true"></div>

  <div class="hero__content is-visible" id="heroContent">
    <div class="hero__center">
      <div class="hero__eyebrow hero__eyebrow--center">
        <span class="hero__line"></span>
        <span>{th.hero.eyebrow}</span>
        <span class="hero__line"></span>
      </div>
      <h1 class="hero__heading hero__heading--center">
        <span class="hero__heading-top">{th.hero.title_top}</span>
        <span class="hero__heading-bottom">
          <HeroHeadingTypewriter
            client:idle
            prefix={tyPrefix}
            words={tyWords}
            speed={75}
            delayBetweenWords={2400}
          />
        </span>
      </h1>
      <div class="hero__actions hero__actions--center">
        <a href={`/${currentLang}/productos`} class="btn btn--solid">
          {th.hero.btn_products}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`/${currentLang}/about`} class="btn btn--ghost">{th.hero.btn_about}</a>
      </div>
    </div>

    <div class="hero__stats">
      {th.hero.stats.map((stat, i) => (
        <>
          <div class="hero__stat">
            <span
              class="hero__stat-num count-anim"
              data-target={(stat as any).number}
              data-suffix={(stat as any).suffix ?? ''}
              data-prefix={(stat as any).prefix ?? ''}>0</span>
            <span class="hero__stat-lbl">{stat.label}</span>
          </div>
          {i < th.hero.stats.length - 1 && <div class="hero__stat-sep"></div>}
        </>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     DIVISIONES
═══════════════════════════════════════ -->
<section class="divisiones">

  <div class="divisiones__head">
    <div class="divisiones__head-inner">
      <p class="section-tag">{th.divisiones.tag}</p>
      <h2 class="section-heading">
        {th.divisiones.title}<br><em>{th.divisiones.title_em}</em>
      </h2>
    </div>
  </div>

  <div class="div-tape-wrap">
    <div class="div-tape">
      {divLoop.map((div, i) => {
        const isClone = i >= divItems.length;
        const idx     = i % divItems.length;
        return (div as any).soon ? (
          <div
            class="div-card div-card--soon"
            style={`--accent: ${div.color}; --img: url('${div.img}')`}
            aria-hidden={isClone ? "true" : "false"}
            aria-label={!isClone ? `${div.title} - Próximamente` : undefined}
          >
            <div class="div-card__bg"></div>
            <div class="div-card__overlay"></div>
            <span class="div-card__soon-badge">Próximamente</span>
            <span class="div-card__num">{String(idx + 1).padStart(2, '0')}</span>
            <div class="div-card__content">
              <span class="div-card__tag">{div.tag}</span>
              <h3 class="div-card__title">{div.title}</h3>
              <p class="div-card__desc">{div.description}</p>
            </div>
            <div class="div-card__line"></div>
          </div>
        ) : (
          <a
            href={`/${currentLang}/${(div as any).slug}`}
            class="div-card"
            style={`--accent: ${div.color}; --img: url('${div.img}')`}
            aria-hidden={isClone ? "true" : undefined}
            tabindex={isClone ? -1 : undefined}
          >
            <div class="div-card__bg"></div>
            <div class="div-card__overlay"></div>
            <span class="div-card__num">{String(idx + 1).padStart(2, '0')}</span>
            <div class="div-card__content">
              <span class="div-card__tag">{div.tag}</span>
              <h3 class="div-card__title">{div.title}</h3>
              <p class="div-card__desc">{div.description}</p>
              <span class="div-card__cta">
                {th.divisiones.link_text}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
            <div class="div-card__line"></div>
          </a>
        );
      })}
    </div>
  </div>

</section>




<!-- ═══════════════════════════════════════
     POR QUÉ ELEGIRNOS
═══════════════════════════════════════ -->
<StickySection zIndex={2} class="sticky-porque">
  <div class="porque">
    <div class="porque__inner">
      <div class="porque__left">
        <p class="section-tag">{th.porque.tag}</p>
        <h2 class="section-heading">
          {th.porque.title}<br><em>{th.porque.title_em}</em>
        </h2>
        <p class="porque__body">{th.porque.body}</p>
        <div class="porque__features">
          {th.porque.features.map((f) => (
            <div class="porque__feature">
              <div class="porque__feature-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>{f.title}</strong>
                <p>{f.description}</p>
              </div>
            </div>
          ))}
        </div>
        <a href={`/${currentLang}/about`} class="btn btn--solid mt-xl">
          {th.porque.btn}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="porque__right">
        <div class="porque__img-frame">
          <img src={th.porque.img} alt={th.porque.img_alt || "Planta de Producción Grupo Ortiz"} loading="lazy" width="800" height="450">
          <div class="porque__badge">
            <span class="porque__badge-num count-anim" data-target={th.porque.badge1_number} data-suffix="" data-prefix="">0</span>
            <span class="porque__badge-lbl">{th.porque.badge1_label}</span>
          </div>
          <div class="porque__badge porque__badge--2">
            <span class="porque__badge-num count-anim" data-target={th.porque.badge2_number} data-suffix="" data-prefix="">0</span>
            <span class="porque__badge-lbl">{th.porque.badge2_label}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</StickySection>


<!-- ═══════════════════════════════════════
     PARALLAX
═══════════════════════════════════════ -->
<StickySection zIndex={3} class="sticky-video">
  <div class="parallax-section">
    <div class="parallax-section__bg">
      <video
        data-src={`https://res.cloudinary.com/${CLOUD}/video/upload/q_auto:best/GO/home/4K.mp4`}
        muted
        playsinline
        loop
        preload="none"
        class="parallax-section__video"
      ></video>
    </div>
    <div class="parallax-section__content">
      <p class="section-tag section-tag--light">{th.parallax.eyebrow}</p>
      <h2 class="section-heading section-heading--light">
        {th.parallax.title} <em>{th.parallax.title_em}</em>
      </h2>
    </div>
  </div>
</StickySection>

<script is:inline>
  (function () {
    var video = document.querySelector('.parallax-section__video[data-src]');
    if (!video) return;
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          video.src = video.dataset.src;
          video.load();
          video.play().catch(function () {});
          io.disconnect();
        }
      });
    }, { rootMargin: '300px' });
    io.observe(video);
  })();
</script>


<!-- ═══════════════════════════════════════
     CERTIFICACIONES
═══════════════════════════════════════ -->
<section class="certs">
  <div class="certs__head">
    <p class="section-tag">{th.certs.tag}</p>
    <h2 class="certs__title">
      <span class="certs__title--black">{th.certs.title}</span><span class="certs__title--orange"> {th.certs.title_em}</span>
    </h2>
  </div>
  <div class="certs__track-wrap">
    <div class="certs__track">
      {certsLoop.map((cert, i) => (
        <div class="cert-card" aria-hidden={i >= certifications.length ? "true" : "false"}>
          <img src={cert.img} alt={i < certifications.length ? cert.code : ""} loading="lazy" class="cert-card__img" width="118" height="84">
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     COMPROMISO
═══════════════════════════════════════ -->
<section class="compromiso">
  <div class="compromiso__card compromiso__card--light">
    <span class="compromiso__eyebrow">{th.compromiso.card1.eyebrow}</span>
    <h3 class="compromiso__title">{th.compromiso.card1.title}</h3>
    <p class="compromiso__text">{th.compromiso.card1.text}</p>
    <div class="compromiso__deco">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
    </div>
  </div>
  <div class="compromiso__card compromiso__card--dark">
    <span class="compromiso__eyebrow">{th.compromiso.card2.eyebrow}</span>
    <h3 class="compromiso__title">{th.compromiso.card2.title}</h3>
    <p class="compromiso__text">{th.compromiso.card2.text}</p>
    <div class="compromiso__deco">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     GLOBAL — VIDEO DE FONDO
═══════════════════════════════════════ -->
<section class="global">
  <div data-fallback-wrap style="position:absolute;inset:0;z-index:0;">
    <video
      id="global-video"
      class="global__video"
      src={`https://res.cloudinary.com/${CLOUD}/video/upload/q_auto:best/${th.global.video}.mp4`}
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster={poster(th.global.video)}
    ></video>
    <!-- Fallback local: se muestra solo si Cloudinary falla -->
    <video
      class="global__video"
      src={`/videos/${th.global.video.replace(/^GO\//, '')}.mp4`}
      autoplay
      muted
      loop
      playsinline
      poster={poster(th.global.video)}
      data-role="fallback"
      style="display:none;"
    ></video>
  </div>
  <div class="global__video-overlay"></div>
  <div class="global__inner">
    <p class="section-tag section-tag--light">{th.global.tag}</p>
    <h2 class="section-heading section-heading--light">
      {th.global.title} <em>{th.global.title_em}</em>
    </h2>
    <p class="global__desc">{th.global.desc}</p>
    <div class="global__stats">
      {th.global.stats.map((s) => (
        <div class="global__stat">
          <span
            class="global__num count-anim"
            data-target={(s as any).number}
            data-suffix={(s as any).suffix ?? ''}
            data-prefix={(s as any).prefix ?? ''}>0</span>
          <span class="global__lbl">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     CTA
═══════════════════════════════════════ -->
<section class="cta">
  <div class="cta__inner">
    <p class="section-tag">{th.cta.tag}</p>
    <h2 class="cta__heading">{th.cta.title} <em>{th.cta.title_em}</em></h2>
    <p class="cta__sub">{th.cta.sub}</p>
    <a href={`/${currentLang}/distribuidor#statsRow`} class="btn btn--solid btn--xl">
      {th.cta.btn}
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>






<script is:inline>

/* ---- COUNTER ANIMATION ---- */
function initCounters() {
  const counters = document.querySelectorAll('.count-anim');
  const duration = 2000;
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const el     = entry.target;
      const target = parseInt(el.getAttribute('data-target'));
      const suffix = el.getAttribute('data-suffix') || '';
      const prefix = el.getAttribute('data-prefix') || '';
      if (entry.isIntersecting) {
        let start = null;
        const tick = (now) => {
          if (!start) start = now;
          const p    = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + Math.floor(ease * target) + suffix;
          if (p < 1) requestAnimationFrame(tick);
          else el.textContent = prefix + target + suffix;
        };
        requestAnimationFrame(tick);
      } else {
        el.textContent = '0';
      }
    });
  }, { threshold: 0.1 });
  counters.forEach(c => observer.observe(c));
}

function initVideoFade() {
  // Dark mode dimming — sin delay, sin esperar canplay
  document.querySelectorAll('.hero__video--fill, .global__video')
    .forEach(el => el.classList.add('is-loaded'));
}

/* ---- INIT ---- */
function init() {
  initCounters();
  initVideoFade();
}

document.addEventListener('DOMContentLoaded', init);
document.addEventListener('astro:page-load', init);
</script>

<style>
  /*
    Estado inicial del hero: oculto via animación con fill-mode:both.
    GSAP sobreescribe con inline styles (mayor especificidad).
    Si GSAP falla o tarda, el fallback CSS revela el texto a los 2.5s.
  */
  :global(.hero__eyebrow),
  :global(.hero__heading-top),
  :global(.hero__heading-bottom),
  :global(.hero__actions--center),
  :global(.hero__stat),
  :global(.hero__stat-sep) {
    animation: hero-fallback-reveal 0.6s ease forwards;
    animation-delay: 0.8s;
    opacity: 0;
    animation-fill-mode: both;
  }

  @keyframes hero-fallback-reveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.hero__eyebrow),
    :global(.hero__heading-top),
    :global(.hero__heading-bottom),
    :global(.hero__actions--center),
    :global(.hero__stat),
    :global(.hero__stat-sep) {
      animation: none;
      opacity: 1;
    }
  }

  /* ── Certificaciones track ── */
  .parallax-section {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
    z-index: 3;
    box-shadow: 0 -24px 64px rgba(0, 0, 0, 0.24);
  }
  .parallax-section__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .parallax-section__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: translateZ(0);
  }
  .parallax-section__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
    pointer-events: none;
  }
  .parallax-section__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 var(--pad);
  }
  .parallax-section__content .section-heading--light,
  .parallax-section__content .section-heading--light em {
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.7);
  }
  .parallax-section__content .section-tag--light {
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.6);
  }

  /* ── Móvil: sección video + sección 65 años — fijas igual que en desktop ── */
  @media (max-width: 768px) {
    /* Doble clase para ganar especificidad sobre .sticky-section { height: auto } */
    :global(.sticky-section.sticky-video),
    :global(.sticky-section.sticky-porque) {
      position : sticky !important;
      top      : 0 !important;
      height   : 100svh !important;
      overflow : hidden !important;
    }

    /* Porque en móvil: llena el alto, imagen oculta para que el contenido quepa */
    :global(.sticky-porque .porque) {
      height  : 100svh !important;
      padding : clamp(28px, 6vw, 52px) 0 !important;
      overflow: hidden !important;
    }
    :global(.sticky-porque .porque__right) {
      display: none !important;
    }
    :global(.sticky-porque .porque__left) {
      max-width: 520px;
      margin   : 0 auto;
    }
  }
</style>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import Lenis from 'lenis';

gsap.registerPlugin(ScrollTrigger);

let homeCtx: gsap.Context | null = null;
let lenis: Lenis | null = null;
let lenisTicker: ((time: number) => void) | null = null;
function destroyLenis() {
  if (lenisTicker) { gsap.ticker.remove(lenisTicker); lenisTicker = null; }
  if (lenis) { lenis.destroy(); lenis = null; }
}

/* ── DIVISIONES: scroll infinito JS + drag ── */
let divTapeRafId: number | null = null;
let divTapeAbortCtrl: AbortController | null = null;

function destroyDivTape() {
  if (divTapeRafId !== null) { cancelAnimationFrame(divTapeRafId); divTapeRafId = null; }
  if (divTapeAbortCtrl) { divTapeAbortCtrl.abort(); divTapeAbortCtrl = null; }
}

function initDivTape() {
  destroyDivTape();
  const tape = document.querySelector<HTMLElement>('.div-tape');
  const wrap = document.querySelector<HTMLElement>('.div-tape-wrap');
  if (!tape || !wrap) return;

  tape.style.animation = 'none';

  const totalWidth = tape.scrollWidth / 2;
  const speed = totalWidth / (60 * 60);

  function cardStep(): number {
    const card = tape.querySelector<HTMLElement>('.div-card');
    return card ? card.offsetWidth + 16 : 320;
  }

  let pos = 0;
  let paused = false;
  let isSnapping = false;
  let snapTarget = 0;

  function goToCard(direction: number) {
    /* direction: -1 = avanzar (siguiente), +1 = retroceder (anterior) */
    const step = cardStep();
    /* Partir desde la posición ya snapeada más cercana, no desde pos raw */
    const base = Math.round(pos / step) * step;
    let target = base + direction * step;
    /* Resolver borde del ciclo infinito */
    while (target - pos > totalWidth / 2) target -= totalWidth;
    while (pos - target > totalWidth / 2) target += totalWidth;
    snapTarget = target;
    isSnapping = true;
  }

  function tick() {
    if (isSnapping) {
      pos += (snapTarget - pos) * 0.14;
      if (Math.abs(snapTarget - pos) < 0.5) {
        pos = snapTarget;
        isSnapping = false;
        while (pos > 0) pos -= totalWidth;
        while (pos < -totalWidth) pos += totalWidth;
      }
    } else if (!paused) {
      pos -= speed;
      if (pos <= -totalWidth) pos += totalWidth;
    }
    tape.style.transform = `translateX(${pos}px)`;
    divTapeRafId = requestAnimationFrame(tick);
  }
  divTapeRafId = requestAnimationFrame(tick);

  let isDragging = false;
  let hasDragged = false;
  let dragStartX = 0;
  let dragStartPos = 0;

  divTapeAbortCtrl = new AbortController();
  const { signal } = divTapeAbortCtrl;

  wrap.addEventListener('mouseenter', () => { paused = true; }, { signal });
  wrap.addEventListener('mouseleave', () => {
    paused = false;
    isDragging = false;
    hasDragged = false;
    wrap.classList.remove('is-grabbing');
  }, { signal });

  /* ── Drag con ratón: arrastra y suelta → snap al más cercano ── */
  tape.addEventListener('mousedown', (e: MouseEvent) => {
    /* Evitar selección de texto/elementos al arrastrar */
    e.preventDefault();
    isDragging = true;
    isSnapping = false;
    hasDragged = false;
    dragStartX = e.clientX;
    dragStartPos = pos;
  }, { signal });

  document.addEventListener('mousemove', (e: MouseEvent) => {
    if (!isDragging) return;
    const delta = e.clientX - dragStartX;
    if (!hasDragged && Math.abs(delta) > 6) {
      hasDragged = true;
      wrap.classList.add('is-grabbing');
    }
    if (hasDragged) {
      /* Seguir el dedo libremente mientras arrastra */
      pos = dragStartPos + delta;
      while (pos > 0) pos -= totalWidth;
      while (pos < -totalWidth) pos += totalWidth;
    }
  }, { signal });

  document.addEventListener('mouseup', () => {
    if (!isDragging) return;
    isDragging = false;
    wrap.classList.remove('is-grabbing');
    if (hasDragged) {
      /* Snap al producto más cercano según cuánto se arrastró */
      const dragged = pos - dragStartPos;
      const step = cardStep();
      /* Si arrastró más de la mitad de una tarjeta → avanzar/retroceder */
      const dir = Math.abs(dragged) > step * 0.3
        ? (dragged < 0 ? -1 : 1)
        : 0;
      goToCard(dir);
      /* Bloquar el click siguiente para no navegar al soltar */
      tape.addEventListener('click', (ev) => ev.preventDefault(), { once: true, signal });
    }
    hasDragged = false;
  }, { signal });
}

function run() {
  /* 1. Limpiar todo el estado GSAP y Lenis anteriores */
  if (homeCtx) { homeCtx.revert(); homeCtx = null; }
  destroyLenis();
  destroyDivTape();

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.set(
      '.hero__eyebrow, .hero__heading-top, .hero__heading-bottom, .hero__actions--center, .hero__stat, .hero__stat-sep',
      { autoAlpha: 1, clearProps: 'transform' }
    );
    return;
  }

  /*
    2. Scroll instantáneo al top.
    { behavior: 'instant' } ignora el scroll-behavior: smooth del CSS global,
    así el layout está en posición 0 antes de que ScrollTrigger calcule offsets.
  */
  const isMobile = window.innerWidth <= 768;

  /* Solo en desktop: scroll al top para que ScrollTrigger calcule bien los pins */
  if (!isMobile) window.scrollTo({ top: 0, behavior: 'instant' });

  requestAnimationFrame(() => requestAnimationFrame(() => {

    /* ── Lenis solo en desktop — en móvil el scroll nativo es más fiable ── */
    if (!isMobile) {
      lenis = new Lenis({
        duration: 1.4,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });
      lenis.on('scroll', ScrollTrigger.update);
      lenisTicker = (time: number) => { lenis!.raf(time * 1000); };
      gsap.ticker.add(lenisTicker);
      gsap.ticker.lagSmoothing(0);

      /* Carrusel de divisiones con drag y scroll infinito */
      initDivTape();
    }

    homeCtx = gsap.context(() => {

      /* ── HERO: estado inicial ── */
      gsap.set('.hero__eyebrow',         { autoAlpha: 0, y: 28 });
      gsap.set('.hero__heading-top',     { autoAlpha: 0, y: 44 });
      gsap.set('.hero__heading-bottom',  { autoAlpha: 0, y: 32 });
      gsap.set('.hero__actions--center', { autoAlpha: 0, y: 22 });
      gsap.set('.hero__stat, .hero__stat-sep', { autoAlpha: 0 });

      /* ── HERO: entrada ── */
      gsap.timeline({
        delay: 0.1,
        defaults: { ease: 'power3.out' },
        onComplete() { gsap.set('.hero__stat', { clearProps: 'transform' }); }
      })
        .to('.hero__eyebrow',          { autoAlpha: 1, y: 0, duration: 0.85 })
        .to('.hero__heading-top',      { autoAlpha: 1, y: 0, duration: 0.90 }, '-=0.52')
        .to('.hero__heading-bottom',   { autoAlpha: 1, y: 0, duration: 0.85 }, '-=0.65')
        .to('.hero__actions--center',  { autoAlpha: 1, y: 0, duration: 0.75 }, '-=0.42')
        .to('.hero__stat, .hero__stat-sep', {
          autoAlpha: 1, duration: 0.55, stagger: { amount: 0.35 }
        }, '-=0.32');

      /* ── HERO: parallax video (solo desktop) ── */
      if (!isMobile) {
        gsap.to('.hero__video-wrap', {
          yPercent: 20, ease: 'none',
          scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1.5 }
        });
      }

      /* ── VIDEO MÁQUINA: parallax en móvil (sección CSS-sticky) ──
         El video panea hacia arriba mientras el usuario hace scroll
         a través de la sección. scale(1.15) da margen para que
         el movimiento no exponga bordes negros.                        */
      if (isMobile) {
        gsap.fromTo('.parallax-section__video',
          { yPercent: 5, scale: 1.15 },
          {
            yPercent : -5,
            scale    : 1.15,
            ease     : 'none',
            scrollTrigger: {
              trigger : '.sticky-section.sticky-video',
              start   : 'top top',
              end     : 'bottom top',
              scrub   : 1.5,
            }
          }
        );
      }

      /* ── ECO border-dissolve ── */
      gsap.to('.hero__eco-overlay', {
        opacity: 1, ease: 'power3.in',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: '75% top', scrub: 1 }
      });
      gsap.to('.hero__video-wrap', {
        opacity: 0, ease: 'power2.in',
        scrollTrigger: { trigger: '.hero', start: '15% top', end: '80% top', scrub: 1 }
      });

      /* ── DIVISIONES ── */
      gsap.from('.divisiones__head-inner', {
        autoAlpha: 0, y: 40, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: '.divisiones__head', start: 'top 92%' }
      });
      gsap.from('.div-tape-wrap', {
        autoAlpha: 0, y: 30, duration: 1, ease: 'power3.out',
        scrollTrigger: { trigger: '.div-tape-wrap', start: 'top 95%' }
      });

      /* ── PORQUE ELEGIRNOS — responsive ── */
      gsap.matchMedia().add({
        '(min-width: 1101px)': () => {
          gsap.from('.porque__left', {
            autoAlpha: 0, x: -64, duration: 1.05, ease: 'power3.out',
            scrollTrigger: { trigger: '.porque__inner', start: 'top 78%' }
          });
          gsap.from('.porque__right', {
            autoAlpha: 0, x: 64, duration: 1.05, ease: 'power3.out',
            scrollTrigger: { trigger: '.porque__inner', start: 'top 78%' }
          });
          gsap.to('.porque__img-frame img', {
            yPercent: -8, ease: 'none',
            scrollTrigger: { trigger: '.porque__right', start: 'top bottom', end: 'bottom top', scrub: 1.5 }
          });
          gsap.from('.compromiso__card--light', {
            autoAlpha: 0, x: -72, duration: 0.95, ease: 'power3.out',
            scrollTrigger: { trigger: '.compromiso', start: 'top 82%' }
          });
          gsap.from('.compromiso__card--dark', {
            autoAlpha: 0, x: 72, duration: 0.95, ease: 'power3.out',
            scrollTrigger: { trigger: '.compromiso', start: 'top 82%' }
          });
        },
        '(max-width: 1100px)': () => {
          gsap.from('.porque__left, .porque__right', {
            autoAlpha: 0, y: 40, duration: 0.9, ease: 'power3.out',
            stagger: 0.18,
            scrollTrigger: { trigger: '.porque__inner', start: 'top 95%' }
          });
          gsap.from('.compromiso__card', {
            autoAlpha: 0, y: 40, duration: 0.9, ease: 'power3.out',
            stagger: 0.18,
            scrollTrigger: { trigger: '.compromiso', start: 'top 95%' }
          });
        }
      });

      /* Decorativos SVG */
      gsap.to('.compromiso__deco', {
        rotation: 22, ease: 'none',
        scrollTrigger: { trigger: '.compromiso', start: 'top bottom', end: 'bottom top', scrub: 2 }
      });

      /* ── CERTIFICACIONES ── */
      gsap.from('.certs__title', {
        autoAlpha: 0, y: 50, duration: 0.9, ease: 'power3.out',
        scrollTrigger: { trigger: '.certs__head', start: 'top 92%' }
      });

      /* ── GLOBAL ── */
      gsap.from('.global__inner .section-tag, .global__inner .section-heading--light, .global__desc', {
        autoAlpha: 0, y: 36, duration: 0.85, ease: 'power3.out',
        stagger: 0.14,
        scrollTrigger: { trigger: '.global__inner', start: 'top 92%' }
      });
      gsap.from('.global__stat', {
        autoAlpha: 0, y: 28, duration: 0.7, ease: 'power3.out',
        stagger: 0.1,
        scrollTrigger: { trigger: '.global__stats', start: 'top 95%' }
      });

      ScrollTrigger.refresh();
    });
  }));
}

document.addEventListener('DOMContentLoaded', run);
document.addEventListener('astro:page-load', run);

/* Limpiar Lenis, GSAP y carrusel al navegar FUERA del home */
document.addEventListener('astro:before-swap', () => {
  destroyDivTape();
  destroyLenis();
  if (homeCtx) { homeCtx.revert(); homeCtx = null; }
  ScrollTrigger.getAll().forEach(t => t.kill());
});

/* bfcache: restauración desde caché con botón Atrás del navegador */
window.addEventListener('pageshow', (e) => { if (e.persisted) run(); });
</script>

<Footer currentLang={currentLang} />
</BaseLayout>