---
// ─────────────────────────────────────────────────────────────────────────────
// QUIENES SOMOS — [lang]/index.astro
// ─────────────────────────────────────────────────────────────────────────────
export const prerender = true;  // ← AGREGAR ESTA LÍNEA
import "../../styles/global.css";
import "../../styles/quienessomos.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import { languages, translations } from "../../i18n";

interface TimelineEvent  { year: string; title: string; short: string; img: string; description: string; }
interface InfraStat      { number: string; label: string; desc: string; icon: string; }
interface PlantaLocation { key: string; number: string; badge: string; }
interface InstalacionItem{ id: string; num: string; title: string; tag: string; desc: string; link: string; soon: boolean; thumb?: string; }
interface CapacidadItem  { num: string; label: string; width: number; delay: number; }
interface ValorItem      { title: string; description: string; }

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = lang && lang in translations ? lang : "es";
const t  = translations[currentLang as keyof typeof translations];
const qs = t.quienes_somos as any;

const tlEvents      = qs.timeline.events        as TimelineEvent[];
const infraStats    = qs.infraestructura.stats  as InfraStat[];
const plantaLocs    = qs.plantas.locations      as PlantaLocation[];
const instalaciones = qs.instalaciones.items    as InstalacionItem[];
const capacidad     = qs.capacidad.items        as CapacidadItem[];
const valores       = qs.valores.items          as ValorItem[];
const valoresDup    = [...valores, ...valores];

const isRTL = currentLang === "ar";

const CLOUD = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dfuzfdrat';
const toVideoSrc = (v: string) =>
  v.startsWith('/') || v.startsWith('http') ? v
  : `https://res.cloudinary.com/${CLOUD}/video/upload/q_auto:best/${v}.mp4`;

// ─────────────────────────────────────────────────────────────────────────────
// ICONOS POR VALOR
// ─────────────────────────────────────────────────────────────────────────────
const valorIcons: Record<string, string> = {
  "responsabilidad": `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  "confianza":       `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 7.65l8.42 8.42 8.42-8.42a5.4 5.4 0 0 0 0-7.65z"/></svg>`,
  "pasion":          `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
  "perseverancia":   `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>`,
  "disciplina":      `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1" ry="1"/><polyline points="9 12 11 14 15 10"/></svg>`,
  "proactividad":    `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>`,
  "respeto":         `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
};
const iconFallback = `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`;

function getValorIcon(title: string): string {
  const key = title.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
  return valorIcons[key] ?? iconFallback;
}
---

<BaseLayout title={qs.meta_title} description={qs.meta_description || ""} canonicalSlug="about/" currentLang={currentLang}>
    <!-- Carga diferida del CSS pesado -->
  
  
  <h1 class="sr-only">{qs.meta_title}</h1>

  <section class="quienes-somos" dir={isRTL ? "rtl" : "ltr"}>
    <div class="container">

      <!-- TIMELINE -->
      <div class="tl-block">
        <div class="tl-video-background-container">
          <video class="tl-video-background" autoplay loop muted playsinline preload="none" poster={qs.timeline.video_poster}>
            <source src={toVideoSrc(qs.timeline.video_bg)} type="video/mp4"  />
          </video>
        </div>
        <div class="tl-wrapper">
          <div class="tl-left">
            <h2 class="tl-main-title">
              <span class="tl-title-white">{qs.timeline.title_white}</span><br />
              <span class="tl-title-orange">{qs.timeline.title_orange}</span>
            </h2>
            <h3 class="tl-event-title" id="tl-event-title">{tlEvents[0].title}</h3>
            <p class="tl-description" id="tl-description">{tlEvents[0].description}</p>
            <div class="tl-navigation">
              <button class="tl-nav-btn tl-prev" aria-label={qs.timeline.nav_prev}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <div class="tl-progress" role="progressbar" aria-valuemin={0} aria-valuemax={100}>
                <div class="tl-progress-bar" id="tl-progress-bar"></div>
              </div>
              <button class="tl-nav-btn tl-next" aria-label={qs.timeline.nav_next}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
              <div class="tl-counter" aria-live="polite">
                <span class="tl-counter-current" id="tl-counter">01</span>
                <span class="tl-counter-divider" aria-hidden="true">/</span>
                <span>{String(tlEvents.length).padStart(2, "0")}</span>
              </div>
            </div>
          </div>
          <div class="tl-right">
            <div class="tl-cards-container" id="tl-cards" role="list">
              <div class="tl-track" id="tl-track">
            {tlEvents.map((ev, i) => (
  <div
    class={`tl-card${i === 0 ? " active" : ""}`}
    data-index={i}
    data-title={ev.title}
    data-description={ev.description}
    role="listitem"
    tabindex="0"
    aria-label={`${ev.year}: ${ev.title}`}
  >
    <div class="tl-card-bg" style={`background-image: url('${ev.img}');`} role="img" aria-hidden="true"></div>
    <div class="tl-card-overlay" aria-hidden="true"></div>
    <div class="tl-card-content">
      <div class="tl-card-year">{ev.year}</div>
      <div class="tl-card-info">
        <h3 class="tl-card-title">{ev.title}</h3>
        <p class="tl-card-text">{ev.short}</p>
      </div>
    </div>
<!-- Info overlay para móvil (tap) -->
<div class="tl-card-mobile-info" aria-hidden="true">
  <div class="tl-card-mobile-year">{ev.year}</div>
  <div class="tl-card-mobile-title">{ev.title}</div>
  <div class="tl-card-mobile-divider"></div>
  <p class="tl-card-mobile-desc">{ev.description}</p>
</div>
    <!-- Botón hint tap -->
    <div class="tl-card-tap-hint" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="16"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
    </div>
  </div>
))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- FILOSOFIA Y VISION -->
      <div class="mision-vision-block">
        <div class="mv-grid">

          <!-- FILOSOFÍA -->
          <div class="mv-card dark" style={`background-image: url('${qs.filosofia.img}');`}>
            <div class="mv-content">
              <span class="mv-label">{qs.filosofia.label}</span>
              <h3>{qs.filosofia.title}</h3>
              <span class="mv-divider" aria-hidden="true"></span>
              <ul class="mv-list">
                {(qs.filosofia.items as string[]).map((item, i) => (
                  <li class="mv-list-item">
                    <span class="mv-item-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                    <span class="mv-item-text">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="mv-icon-bg" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle>
              </svg>
            </div>
          </div>

          <!-- VISIÓN -->
          <div class="mv-card orange" style={`background-image: url('${qs.vision.img}');`}>
            <div class="mv-content">
              <span class="mv-label">{qs.vision.label}</span>
              <h3>{qs.vision.title}</h3>
              <span class="mv-divider" aria-hidden="true"></span>
              <ul class="mv-list">
                {(qs.vision.items as string[]).map((item, i) => (
                  <li class="mv-list-item">
                    <span class="mv-item-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                    <span class="mv-item-text">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="mv-icon-bg" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle>
              </svg>
            </div>
          </div>

        </div>
      </div>

      <!-- INFRAESTRUCTURA -->
      <section class="infraestructura-section">
        <h3 class="block-title block-title--no-subtitle">
          <span class="title-white">{qs.infraestructura.title_white}</span>{" "}
          <span class="title-orange">{qs.infraestructura.title_orange}</span>
        </h3>
        <div class="infraestructura-grid">
          {infraStats.map((stat) => (
            <div class="infra-card">
              <div class="infra-number">
                {stat.icon === "globe" ? (
                  <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
                    <path d="M2 12h20"></path>
                  </svg>
                ) : (stat.number)}
              </div>
              <h3>{stat.label}</h3>
              <p>{stat.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- MAPA -->
      <div class="plantas-map-block" dir="ltr">
        <h3 class="block-title">{qs.plantas.title}</h3>
        <p class="block-subtitle">{qs.plantas.subtitle}</p>
        <div class="map-container">
          <img src={qs.plantas.map_img}         alt="Mapa de México"       class="mexico-map" />
          <img src={qs.plantas.layer_michoacan} alt="Michoacán"            class="map-layer" data-layer="michoacan" />
          <img src={qs.plantas.layer_monterrey} alt="Monterrey"            class="map-layer" data-layer="monterrey" />
          <img src={qs.plantas.layer_both}      alt="Ambas ubicaciones"   class="map-layer" data-layer="both" />
          {plantaLocs.map((loc) => (
            <div class={`map-location location-${loc.key}`} data-location={loc.key} aria-label={loc.badge}>
              <div class="location-number">{loc.number}</div>
              <div class="location-badge">{loc.badge}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- INSTALACIONES -->
      <div class="instalaciones-block">
        <div class="inst-header">
          <h3 class="inst-title-inline">
            <span class="title-white">{qs.instalaciones.title_white}</span>&nbsp;
            <span class="title-orange">{qs.instalaciones.title_orange}</span>
          </h3>
          <p class="block-subtitle">{qs.instalaciones.subtitle}</p>
        </div>
        <div class="inst-grid">
          {instalaciones.map((inst) => (
            <div class={`inst-card${inst.soon ? " inst-card--soon" : ""}`} data-tour={inst.id}>
              <div class="inst-card-media">
                {inst.thumb ? (
                  <>
                    <img src={inst.thumb} alt={inst.title} class="inst-thumb-img" loading="lazy"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                    <div class="inst-placeholder-img" style="display:none"><div class="inst-placeholder-pattern"></div></div>
                  </>
                ) : (
                  <div class="inst-placeholder-img" style={`background:linear-gradient(135deg,${inst.soon ? "#111 0%,#1e1e1e 50%,#111" : "#1a1a1a 0%,#2d2d2d 50%,#1a1a1a"} 100%)`}>
                    <div class="inst-placeholder-pattern" style={inst.soon ? "opacity:0.25" : ""}></div>
                  </div>
                )}
                <div class={`inst-card-badge${inst.soon ? " inst-card-badge--soon" : ""}`}>
                  {inst.soon ? (
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  ) : (
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
                  )}
                  {inst.soon ? qs.instalaciones.badge_soon : qs.instalaciones.badge_tour}
                </div>
              </div>
              <div class="inst-card-body">
                <div class="inst-card-meta"><span class="inst-tag">{inst.tag}</span></div>
                <h4 class="inst-card-title">{inst.title}</h4>
                <p class="inst-card-desc">{inst.desc}</p>
                {inst.soon ? (
                  <button class="inst-btn inst-btn--disabled" disabled aria-disabled="true">
                    <span>{qs.instalaciones.btn_soon}</span>
                    <svg class="inst-btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  </button>
                ) : (
                  <a href={inst.link} target="_blank" rel="noopener noreferrer" class="inst-btn inst-btn--primary" aria-label={`${qs.instalaciones.btn_tour}: ${inst.title}`}>
                    <span>{qs.instalaciones.btn_tour}</span>
                    <svg class="inst-btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  </a>
                )}
              </div>
              <div class="inst-card-number" aria-hidden="true">{inst.num}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- CAPACIDAD -->
      <div class="plantas-breakdown-block">
        <h3 class="block-title">{qs.capacidad.title}</h3>
        <p class="block-subtitle">{qs.capacidad.subtitle}</p>
        <div class="progress-grid">
          <div class="progress-column">
            {capacidad.slice(0, 5).map((item) => (
              <div class="tech-card" data-plants={item.num} data-delay={item.delay}>
                <div class="tech-card-left">
                  <span class="tech-number">{item.num}</span>
                  <span class="tech-label">{parseInt(item.num) === 1 ? qs.capacidad.planta_label : qs.capacidad.plantas_label}</span>
                </div>
                <div class="tech-card-right">
                  <div class="tech-info-row"><h4 class="tech-name">{item.label}</h4></div>
                  <div class="tech-progress-container">
                    <div class="tech-progress-bar" role="progressbar" aria-valuenow={item.width} aria-valuemin={0} aria-valuemax={100}>
                      <div class="tech-progress-fill" data-width={item.width}></div>
                    </div>
                    <div class="tech-ticks" aria-hidden="true"><span>|</span><span>|</span><span>|</span><span>|</span><span>|</span></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="progress-column">
            {capacidad.slice(5).map((item) => (
              <div class="tech-card" data-plants={item.num} data-delay={item.delay}>
                <div class="tech-card-left">
                  <span class="tech-number">{item.num}</span>
                  <span class="tech-label">{parseInt(item.num) === 1 ? qs.capacidad.planta_label : qs.capacidad.plantas_label}</span>
                </div>
                <div class="tech-card-right">
                  <div class="tech-info-row"><h4 class="tech-name">{item.label}</h4></div>
                  <div class="tech-progress-container">
                    <div class="tech-progress-bar" role="progressbar" aria-valuenow={item.width} aria-valuemin={0} aria-valuemax={100}>
                      <div class="tech-progress-fill" data-width={item.width}></div>
                    </div>
                    <div class="tech-ticks" aria-hidden="true"><span>|</span><span>|</span><span>|</span><span>|</span><span>|</span></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- VALORES -->
      <div class="valores-section">
        <h3 class="block-title">{qs.valores.title}</h3>
        <p class="block-subtitle">{qs.valores.subtitle}</p>
        <div class="valores-track-wrap" role="region" aria-label={qs.valores.title}>
          <div class="valores-track" id="valores-track">
            {valoresDup.map((v, i) => (
              <div
                class="valor-card"
                aria-hidden={i >= valores.length ? "true" : undefined}
              >
                <div class="valor-card-visual">
                  <span class="valor-card-num" aria-hidden="true">{String((i % valores.length) + 1).padStart(2, '0')}</span>
                  <div class="valor-card-icon-wrap" aria-hidden="true" set:html={getValorIcon(v.title)} />
                </div>
                <div class="valor-card-content">
                  <h4 class="valor-card-title">{v.title}</h4>
                  <p class="valor-card-desc">{v.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>
  <Footer currentLang={currentLang} />
</BaseLayout>

<script>
  function initTL() {
    const container   = document.getElementById("tl-cards")        as HTMLElement | null;
    const track       = document.getElementById("tl-track")         as HTMLElement | null;
    const prevBtn     = document.querySelector<HTMLButtonElement>(".tl-prev");
    const nextBtn     = document.querySelector<HTMLButtonElement>(".tl-next");
    const counter     = document.getElementById("tl-counter");
    const progressBar = document.getElementById("tl-progress-bar") as HTMLElement | null;
    const description = document.getElementById("tl-description")  as HTMLElement | null;
    const eventTitle  = document.getElementById("tl-event-title")  as HTMLElement | null;

    if (!container || !track) return;
    if (track.dataset.initialized) return;
    track.dataset.initialized = "true";

    const realCards = Array.from(track.querySelectorAll<HTMLElement>(".tl-card"));
    const n = realCards.length;
    if (!n) return;

    // Clonar primera y última card para loop infinito sin salto visible
    const cloneLast  = realCards[n - 1].cloneNode(true) as HTMLElement;
    const cloneFirst = realCards[0].cloneNode(true)     as HTMLElement;
    cloneLast.setAttribute("aria-hidden", "true");
    cloneFirst.setAttribute("aria-hidden", "true");
    track.insertBefore(cloneLast, realCards[0]);
    track.appendChild(cloneFirst);

    // allCards: [cloneLast(0), real0(1)…realN-1(N), cloneFirst(N+1)]
    const allCards = Array.from(track.querySelectorAll<HTMLElement>(".tl-card"));

    let idx        = 1;
    let isMoving   = false;
    let isDragging = false, hasMoved = false;
    let dragStartX = 0, dragStartTx = 0;

    function getTranslate(i: number): number {
      const style = getComputedStyle(track!);
      const gap   = parseFloat(style.gap) || parseFloat(style.columnGap) || 40;
      let offset  = 0;
      for (let j = 0; j < i; j++) offset += (allCards[j]?.offsetWidth || 380) + gap;
      const cw = allCards[i]?.offsetWidth || 380;
      return -(offset + cw / 2 - container!.offsetWidth / 2);
    }

    function setTranslate(tx: number, animated: boolean) {
      track!.style.transition = animated
        ? "transform 0.5s cubic-bezier(0.25,0.8,0.25,1)"
        : "none";
      track!.style.transform = `translateX(${tx}px)`;
    }

    function getRealIdx(i: number): number {
      if (i === 0)     return n - 1;
      if (i === n + 1) return 0;
      return i - 1;
    }

    function fadeSwap(el: HTMLElement | null, text: string) {
      if (!el) return;
      el.style.opacity = "0";
      setTimeout(() => { el.textContent = text; el.style.opacity = "1"; }, 200);
    }

    function updateProgress(ri: number) {
      if (!progressBar) return;
      progressBar.style.width = n <= 1 ? "100%" : `${((ri + 1) / n) * 100}%`;
    }

    function updateUI(ri: number) {
      const card = realCards[ri];
      if (!card) return;
      fadeSwap(eventTitle,  card.dataset.title       ?? "");
      fadeSwap(description, card.dataset.description ?? "");
      if (counter) counter.textContent = String(ri + 1).padStart(2, "0");
      updateProgress(ri);
    }

    function goTo(newIdx: number, animated = true) {
      idx = newIdx;
      const ri = getRealIdx(idx);
      allCards.forEach((c, i) => c.classList.toggle("active", i === idx));
      setTranslate(getTranslate(idx), animated);
      updateUI(ri);
      isMoving = animated;
    }

    // Al terminar la transición: saltar al card real si aterrizamos en un clon
    track.addEventListener("transitionend", (e: TransitionEvent) => {
      if (e.propertyName !== "transform") return;
      isMoving = false;
      if (idx === 0)     goTo(n,     false);
      if (idx === n + 1) goTo(1,     false);
    });

    prevBtn?.addEventListener("click", () => { if (!isMoving) goTo(idx - 1); });
    nextBtn?.addEventListener("click", () => { if (!isMoving) goTo(idx + 1); });

    // Drag mouse
    container.addEventListener("mousedown", (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest("button, a")) return;
      e.preventDefault();
      isDragging = true; hasMoved = false;
      dragStartX = e.clientX; dragStartTx = getTranslate(idx);
      container.style.cursor = "grabbing";
      track.style.transition = "none";
    });
    window.addEventListener("mousemove", (e: MouseEvent) => {
      if (!isDragging) return;
      const delta = e.clientX - dragStartX;
      if (Math.abs(delta) > 5) hasMoved = true;
      track.style.transform = `translateX(${dragStartTx + delta}px)`;
    });
    window.addEventListener("mouseup", (e: MouseEvent) => {
      if (!isDragging) return;
      isDragging = false; container.style.cursor = "grab";
      const delta = e.clientX - dragStartX;
      if (Math.abs(delta) > 60 && !isMoving) goTo(delta < 0 ? idx + 1 : idx - 1);
      else setTranslate(getTranslate(idx), true);
    });

    // Touch
    container.addEventListener("touchstart", (e: TouchEvent) => {
      isDragging = true; hasMoved = false;
      dragStartX = e.touches[0].clientX; dragStartTx = getTranslate(idx);
      track.style.transition = "none";
    }, { passive: true });
    container.addEventListener("touchmove", (e: TouchEvent) => {
      if (!isDragging) return;
      const delta = e.touches[0].clientX - dragStartX;
      if (Math.abs(delta) > 5) hasMoved = true;
      track.style.transform = `translateX(${dragStartTx + delta}px)`;
    }, { passive: true });
    container.addEventListener("touchend", (e: TouchEvent) => {
      if (!isDragging) return;
      isDragging = false;
      const delta = e.changedTouches[0].clientX - dragStartX;
      if (Math.abs(delta) > 50 && !isMoving) goTo(delta < 0 ? idx + 1 : idx - 1);
      else setTranslate(getTranslate(idx), true);
    }, { passive: true });

    // Teclado
    document.addEventListener("keydown", (e: KeyboardEvent) => {
      const tl = document.querySelector(".tl-block");
      if (!tl) return;
      const { top, bottom } = tl.getBoundingClientRect();
      if (top >= window.innerHeight || bottom <= 0) return;
      if (e.key === "ArrowLeft"  && !isMoving) { e.preventDefault(); goTo(idx - 1); }
      if (e.key === "ArrowRight" && !isMoving) { e.preventDefault(); goTo(idx + 1); }
    });

    // Click en card adyacente para navegar hacia ella
    allCards.forEach((card, i) => {
      if (i === 0 || i === n + 1) return;
      card.addEventListener("click", () => {
        if (hasMoved) return;
        if (i !== idx && !isMoving) goTo(i);
      });
      card.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter" || e.key === " ") { e.preventDefault(); if (!isMoving) goTo(i); }
      });
    });

    // Tap para revelar info en móvil
    if (window.innerWidth <= 767) {
      allCards.forEach((card) => {
        card.addEventListener("click", () => {
          if (hasMoved) return;
          const isOpen = card.classList.contains("tl-info-open");
          allCards.forEach(c => c.classList.remove("tl-info-open"));
          if (!isOpen) card.classList.add("tl-info-open");
        });
      });
    }

    // Recalcular posición al cambiar tamaño de ventana
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => setTranslate(getTranslate(idx), false), 100);
    });

    if (description) description.style.transition = "opacity 0.3s ease";
    if (eventTitle)  eventTitle.style.transition  = "opacity 0.3s ease";
    goTo(1, false);

    // Autoplay solo en desktop
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function startAuto() {
      if (window.innerWidth <= 767) return;
      stopAuto();
      autoTimer = setInterval(() => {
        if (!isMoving && !isDragging) goTo(idx + 1);
      }, 4000);
    }

    function stopAuto() {
      if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    }

    container.addEventListener("mouseenter", stopAuto);
    container.addEventListener("mouseleave", startAuto);
    prevBtn?.addEventListener("click", () => { stopAuto(); startAuto(); });
    nextBtn?.addEventListener("click", () => { stopAuto(); startAuto(); });

    startAuto();
  }
  

  document.addEventListener("DOMContentLoaded", initTL);
  document.addEventListener("astro:page-load",  initTL);
</script>

<script is:inline>
  function initMapAnimations() {
    const mapBlock        = document.querySelector(".plantas-map-block");
    const michoacanLayer  = document.querySelector(".map-layer[data-layer='michoacan']");
    const monterreyLayer  = document.querySelector(".map-layer[data-layer='monterrey']");
    const bothStatesLayer = document.querySelector(".map-layer[data-layer='both']");
    const michoacanPin    = document.querySelector(".map-location[data-location='michoacan']");
    const monterreyPin    = document.querySelector(".map-location[data-location='monterrey']");
    if (!mapBlock || !michoacanLayer || !monterreyLayer || !bothStatesLayer) return;
    let animationTimeouts = [];
    const resetMap = () => {
      animationTimeouts.forEach(clearTimeout); animationTimeouts = [];
      [michoacanLayer, monterreyLayer, bothStatesLayer, michoacanPin, monterreyPin].forEach((el) => {
        if (el) { el.style.transition = "opacity 0.5s ease"; el.style.opacity = "0"; }
      });
    };
    const playSequence = () => {
      resetMap();
      animationTimeouts.push(setTimeout(() => {
        michoacanLayer.style.transition = "opacity 1.5s ease-in-out"; michoacanLayer.style.opacity = "1";
        if (michoacanPin) { michoacanPin.style.transition = "opacity 1.5s ease-in-out"; michoacanPin.style.opacity = "1"; }
      }, 100));
      animationTimeouts.push(setTimeout(() => {
        michoacanLayer.style.opacity = "0"; if (michoacanPin) michoacanPin.style.opacity = "0";
        monterreyLayer.style.transition = "opacity 1.5s ease-in-out"; monterreyLayer.style.opacity = "1";
        if (monterreyPin) { monterreyPin.style.transition = "opacity 1.5s ease-in-out"; monterreyPin.style.opacity = "1"; }
      }, 3000));
      animationTimeouts.push(setTimeout(() => {
        monterreyLayer.style.opacity = "0";
        bothStatesLayer.style.transition = "opacity 1.5s ease-in-out"; bothStatesLayer.style.opacity = "1";
        [michoacanPin, monterreyPin].forEach((pin) => { if (pin) { pin.style.transition = "opacity 1.5s ease-in-out"; pin.style.opacity = "1"; } });
      }, 6000));
    };
    new IntersectionObserver(
      (entries) => entries.forEach((entry) => entry.isIntersecting ? playSequence() : resetMap()),
      { threshold: 0.25 }
    ).observe(mapBlock);
  }

 function initBreakdownAnimations() {
    const block = document.querySelector(".plantas-breakdown-block");
    if (!block) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.querySelectorAll(".tech-card").forEach((item) => {
          const delay = parseInt(item.getAttribute("data-delay") || "0");
          setTimeout(() => {
            item.classList.add("visible");
            const fill = item.querySelector(".tech-progress-fill");
            if (fill) setTimeout(() => { fill.style.width = fill.getAttribute("data-width") + "%"; }, 100);
          }, delay);
        });
        observer.unobserve(entry.target);
      });
    }, { threshold: 0.1 });
    observer.observe(block);
  }

  function initInfraCardAnimations() {
    const cards = document.querySelectorAll(".infra-card");
    if (!cards.length) return;
    const observer = new IntersectionObserver(
      (entries) => entries.forEach((entry, i) => { if (entry.isIntersecting) setTimeout(() => entry.target.classList.add("visible"), i * 150); }),
      { threshold: 0.2 }
    );
    cards.forEach((card) => observer.observe(card));
  }

  function initValoresBento() {
    const wrap  = document.querySelector(".valores-track-wrap");
    const track = document.querySelector(".valores-track");
    if (!wrap || !track) return;
    // Arranca el scroll sólo cuando la sección entra en viewport
    new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) wrap.classList.add("playing");
        else wrap.classList.remove("playing");
      });
    }, { threshold: 0.15 }).observe(wrap);
  }

  function initAll() { initMapAnimations(); initBreakdownAnimations(); initInfraCardAnimations(); initValoresBento(); }
  document.addEventListener("DOMContentLoaded", initAll);
  document.addEventListener("astro:page-load",  initAll);
</script>