---
/* --- DATA DE LOS SLIDES --- */
const slides = [
  {
    label: "Inicio",
    title: "Búsqueda y Compra",
    subtitle: "Gestión Internacional",
    description: "Identificamos los mejores proveedores en Asia. Nos encargamos de la negociación y compra para asegurar la calidad de tu inversión desde el origen.",
    cta: "Consultar",
    image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop"
  },
  {
    label: "Logística",
    title: "Transporte Seguro",
    subtitle: "Marítimo y Aéreo",
    description: "Coordinamos toda la cadena logística. Desde la fábrica hasta el puerto, garantizando los tiempos de tránsito más eficientes del mercado.",
    cta: "Ver Rutas",
    image: "https://images.unsplash.com/photo-1494412574643-35d3246981d5?q=80&w=2050&auto=format&fit=crop"
  },
  {
    label: "Aduanas",
    title: "Trámites Legales",
    subtitle: "Sin complicaciones",
    description: "Nuestro equipo de expertos gestiona toda la documentación aduanera necesaria para que tu mercancía entre al país sin demoras ni multas.",
    cta: "Asesoría",
    image: "https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?q=80&w=2070&auto=format&fit=crop"
  },
  {
    label: "Contacto",
    title: "Hablemos Hoy",
    subtitle: "Soporte 24/7",
    description: "¿Tienes un proyecto en mente? Nuestro equipo comercial está listo para diseñar una solución a la medida de tus necesidades.",
    cta: "Contactar",
    image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop"
  }
];
---

<section class="hero-section">
  
  <div class="background-layer">
    {slides.map((slide, index) => (
      <div 
        class:list={['bg-image', { active: index === 0 }]}
        style={`background-image: url('${slide.image}')`}
        data-index={index}
      >
        <div class="bg-overlay"></div>
      </div>
    ))}
  </div>

  <div class="main-container">
    
    <header class="header-row">
      <div class="logo-box">
        <span class="logo-symbol">GO</span> <div class="logo-text">
          <span>Grupo Ortiz</span>
          <small>Logística Global</small>
        </div>
      </div>
      <div class="contact-info">
        <span>+52 (55) 1234-5678</span>
      </div>
    </header>

    <div class="center-content">
      
      <nav class="timeline-wrapper">
        <div class="timeline-line"></div>
        <div class="timeline-dots">
          {slides.map((slide, index) => (
            <button class:list={['t-btn', { active: index === 0 }]} data-index={index}>
              <div class="dot-container">
                <div class="pulse-ring"></div>
                <div class="core-dot"></div>
              </div>
              <span class="t-label">{slide.label}</span>
            </button>
          ))}
        </div>
      </nav>

      <div class="content-slider">
        {slides.map((slide, index) => (
          <article class:list={['slide-content', { active: index === 0 }]} data-index={index}>
            
            <div class="col-title">
              <h1>{slide.title}</h1>
              <span class="subtitle">{slide.subtitle}</span>
            </div>

            <div class="col-desc">
              <p>{slide.description}</p>
            </div>

            <div class="col-cta">
              <a href="#" class="cta-button">{slide.cta}</a>
            </div>

          </article>
        ))}
      </div>

    </div> 

    <div class="nav-arrows">
      <button id="prevBtn" aria-label="Anterior">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="nextBtn" aria-label="Siguiente">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

  </div>
</section>

<style>
  /* --- VARIABLES LOCALES (Conectadas a tus variables globales) --- */
  .hero-section {
    /* Mapeamos tus variables globales para consistencia */
    --accent: var(--productos-hover, #fb670b); 
    --font-title: var(--fuente-titulos, 'MorganitePro', sans-serif);
    --font-body: var(--fuente-cuerpo, 'NeueMontreal', sans-serif);
    --text-primary: #f5f5f5;
    --text-muted: #b0b0b0;
    --dark-overlay: rgba(15, 23, 42, 0.7);
    --max-width: 1400px;
    --transition: 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* --- ESTRUCTURA --- */
  .hero-section {
    position: relative;
    width: 100vw;
    height: 100vh;
    min-height: 700px;
    background: #0f172a;
    color: var(--text-primary);
    font-family: var(--font-body);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* --- FONDOS --- */
  .background-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bg-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.2s ease, transform 1.2s ease;
    transform: scale(1.1); /* Zoom inicial */
  }

  .bg-image.active {
    opacity: 1;
    transform: scale(1);
    z-index: 1;
  }

  .bg-overlay {
    position: absolute;
    inset: 0;
    background: var(--dark-overlay);
    /* Efecto de trama de puntos sutil */
    background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  /* --- CONTENEDOR PRINCIPAL --- */
  .main-container {
    position: relative;
    z-index: 10;
    width: 90%;
    max-width: var(--max-width);
    height: 90%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* --- HEADER --- */
  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
  }

  .logo-box {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .logo-symbol {
    font-family: var(--font-title);
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }

  .logo-text {
    border-left: 1px solid rgba(255,255,255,0.3);
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    font-size: 0.9rem;
    line-height: 1.2;
    color: var(--text-muted);
  }

  .contact-info {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  /* --- ÁREA CENTRAL --- */
  .center-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5vh; /* Espacio responsivo */
  }

  /* --- TIMELINE --- */
  .timeline-wrapper {
    position: relative;
    width: 100%;
    height: 80px;
    display: flex;
    align-items: center;
  }

  .timeline-line {
    position: absolute;
    top: 50%;
    left: -100vw;
    right: -100vw;
    height: 1px;
    background: rgba(255, 255, 255, 0.15);
    z-index: 0;
  }

  .timeline-dots {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: space-between;
    z-index: 2;
  }

  .t-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    outline: none;
    width: 120px;
    opacity: 0.6;
    transition: opacity 0.3s;
  }
  .t-btn:hover { opacity: 1; }
  .t-btn.active { opacity: 1; }

  .dot-container {
    position: relative;
    width: 14px;
    height: 14px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .core-dot {
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    transition: all 0.3s;
  }

  .pulse-ring {
    position: absolute;
    width: 40px;
    height: 40px;
    border: 1px solid var(--accent);
    border-radius: 50%;
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .t-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* Active states timeline */
  .t-btn.active .core-dot {
    background: var(--accent);
    transform: scale(1.5);
    box-shadow: 0 0 10px var(--accent);
  }
  .t-btn.active .pulse-ring {
    opacity: 1;
    transform: scale(1);
  }

  /* --- SLIDER DE TEXTO --- */
  .content-slider {
    position: relative;
    min-height: 300px;
  }

  .slide-content {
    position: absolute;
    top: 0; left: 0; width: 100%;
    
    display: grid;
    grid-template-columns: 1.5fr 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
    
    opacity: 0;
    transform: translateY(40px);
    transition: all var(--transition);
    pointer-events: none;
  }

  .slide-content.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  /* Títulos */
  .col-title h1 {
    font-family: var(--font-title);
    font-size: clamp(3rem, 5vw, 6rem); /* Grande y responsivo */
    line-height: 0.9;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }
  .col-title .subtitle {
    font-size: 1.2rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 1px;
  }

  /* Descripción */
  .col-desc {
    border-left: 2px solid var(--accent); /* Línea naranja */
    padding-left: 2rem;
  }
  .col-desc p {
    font-size: 1.1rem;
    line-height: 1.5;
    color: #d1d5db;
    max-width: 500px;
  }

  /* Botón CTA */
  .col-cta {
    display: flex;
    justify-content: flex-end;
  }
  
  .cta-button {
    padding: 15px 40px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 2px;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .cta-button:hover {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 10px 20px rgba(251, 103, 11, 0.3);
    transform: translateY(-2px);
  }

  /* Flechas */
  .nav-arrows {
    display: flex;
    gap: 1rem;
    padding-bottom: 1rem;
  }
  .nav-arrows button {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(5px);
    border: none;
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nav-arrows button:hover {
    background: var(--accent);
    transform: scale(1.1);
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 1024px) {
    .slide-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
    
    .col-desc {
      border-left: none;
      padding-left: 0;
      margin: 0 auto;
    }

    .col-cta {
      justify-content: center;
    }

    .logo-text, .contact-info { display: none; }
    
    .timeline-wrapper {
      margin-bottom: 20px;
    }
  }

  @media (max-width: 600px) {
    .t-label { display: none; }
    .timeline-dots { justify-content: space-evenly; }
    .col-title h1 { font-size: 3.5rem; }
  }
</style>

<script>
  // Lógica del Slider
  function initHeroSlider() {
    const slides = document.querySelectorAll('.bg-image');
    const buttons = document.querySelectorAll('.t-btn');
    const contents = document.querySelectorAll('.slide-content');
    const nextBtn = document.getElementById('nextBtn');
    const prevBtn = document.getElementById('prevBtn');
    
    if (!slides.length) return; // Si no hay slides, no hacemos nada

    let currentIdx = 0;
    const total = slides.length;

    function setSlide(index) {
      // 1. Quitar clase 'active' de todo
      const elements = [...slides, ...buttons, ...contents];
      elements.forEach(el => el.classList.remove('active'));

      // 2. Añadir clase 'active' al índice actual
      if(slides[index]) slides[index].classList.add('active');
      if(buttons[index]) buttons[index].classList.add('active');
      if(contents[index]) contents[index].classList.add('active');
      
      currentIdx = index;
    }

    // Eventos Click en botones de timeline
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-index'));
        setSlide(idx);
      });
    });

    // Eventos Flechas
    nextBtn?.addEventListener('click', () => {
      setSlide((currentIdx + 1) % total);
    });
    
    prevBtn?.addEventListener('click', () => {
      setSlide((currentIdx - 1 + total) % total);
    });

    // Teclado (Opcional)
    document.addEventListener('keydown', (e) => {
      if(e.key === 'ArrowRight') setSlide((currentIdx + 1) % total);
      if(e.key === 'ArrowLeft') setSlide((currentIdx - 1 + total) % total);
    });
  }

  // Inicializar (soporte para View Transitions de Astro)
  document.addEventListener('astro:page-load', initHeroSlider);
  // Inicializar carga normal por si acaso no usas View Transitions
  initHeroSlider();
</script>