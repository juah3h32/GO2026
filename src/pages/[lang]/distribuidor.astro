---
// src/pages/[lang]/distribuidor.astro
import "../../styles/distribuidor.css";
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import { languages, translations } from "../../i18n";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const currentLang = lang && lang in translations ? lang : "es";
const t = translations[currentLang as keyof typeof translations] as any;

const pageData = t.distribuidor || {};

const defaultCards = [
  {
    icon: "ri-stack-line",
    title: "Stock Total",
    desc: "Capacidad para surtir grandes pedidos al instante.",
  },
  {
    icon: "ri-truck-line",
    title: "Envíos 24h",
    desc: "Logística propia. Entregamos en tiempo récord.",
  },
  {
    icon: "ri-shield-check-line",
    title: "Garantía",
    desc: "Cambios físicos sin burocracia ni preguntas.",
  },
  {
    icon: "ri-line-chart-line",
    title: "Mejor Margen",
    desc: "Precios directos de fábrica.",
  },
];

const features =
  pageData.cards && Array.isArray(pageData.cards) && pageData.cards.length > 0
    ? pageData.cards
    : defaultCards;

const stats = pageData.stats || [{ val: 0, symbol: "+", label: "Cargando..." }];
const form = pageData.form || {
  title: "Solicitud",
  desc: "Contáctanos",
  support_label: "SOPORTE",
  labels: {
    name: "Nombre",
    business: "Empresa",
    whatsapp: "Tel",
    email: "Email",
    products: "Productos",
  },
  products_list: ["General"],
  btn: "Enviar",
  success_msg: "Enviado",
};

const heroSubtitle = pageData.hero?.subtitle || "Portal Mayoristas";
const heroTitle = pageData.hero?.title || "Multiplica tus Ingresos";
const heroDesc = pageData.hero?.desc || "Distribuye productos de alta demanda.";
const heroCta = pageData.hero?.cta || "Comenzar";
const metaTitle = pageData.meta_title || "Distribuidor";

const placeholderImg =
  "https://placehold.co/600x900/111/fb670b?text=App+Distribuidor&font=roboto";
---

<BaseLayout title={metaTitle} currentLang={currentLang}>

  <!-- ── HEAD: íconos con preload para garantizar carga antes del paint ── -->
  <Fragment slot="head">
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <!-- preload garantiza que el font de íconos llegue antes del primer render -->
    <link
      rel="preload"
      href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css"
      as="style"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css"
    />
  </Fragment>

  <!-- ── SCRIPTS CDN en orden, is:inline, SIN defer ── -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.7.0/vanilla-tilt.min.js" is:inline></script>

  <!-- Efecto de revelación al enviar formulario -->
  <div class="reveal-container" id="revealEffect">
    <div class="reveal-bg"></div>
    <div class="reveal-content">
      <img
        src="/assets/cel.png"
        alt="Éxito"
        onerror={`this.src='${placeholderImg}'`}
      />
      <div class="reveal-text">{form.success_msg}</div>
    </div>
  </div>

  <!-- Canvas de fondo con partículas Three.js -->
  <div id="canvas-bg" aria-hidden="true"></div>

  <div class="distribuidor-container">

    <!-- Hero Section -->
    <section class="hero-split">
      <div class="hero-content">
        <h4 class="gs-fade">{heroSubtitle}</h4>
        <h1 class="gs-title" set:html={heroTitle} />
        <p class="gs-fade">{heroDesc}</p>
        <div class="gs-fade">
          <a href="#formulario" class="btn-cta">
            {heroCta}
            <i class="ri-arrow-right-line"></i>
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <img
          src="/assets/cel.png"
          alt="Aplicación de distribuidor"
          class="hero-img gs-img"
          onerror={`this.src='${placeholderImg}'`}
          loading="eager"
        />
      </div>
    </section>

    <!-- Features Grid -->
    <div class="grid-features">
      {
        features.map((card: any) => (
          <div class="card js-tilt" data-tilt>
            <div class="card-header">
              <div class="card-icon-wrap">
                <i class={card.icon} />
              </div>
              <h3>{card.title}</h3>
            </div>
            <p>{card.desc}</p>
          </div>
        ))
      }
    </div>

    <!-- Dots carrusel (móvil) -->
    <div class="carousel-dots" id="cardsDots"></div>

    <!-- Stats Section -->
    <div class="stats-row gs-reveal" id="statsRow">
      {
        stats.map((stat: any) => (
          <div class="stat-box">
            <div class="stat-number">
              <span class="counter" data-target={stat.val}>0</span>
              <span class="stat-symbol">{stat.symbol}</span>
            </div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))
      }
    </div>

    <!-- Form Section -->
    <section id="formulario" class="form-section gs-reveal">
      <div class="form-cta">
        <h2 set:html={form.title} />
        <p>{form.desc}</p>

        <div class="support-info">
          <strong class="support-label">{form.support_label}</strong>
          <span class="support-number">
            <i class="ri-whatsapp-line"></i> 443 207 2593
          </span>
        </div>
      </div>

      <div class="form-inputs">
        <form id="distribuidor-form">
          <div class="input-row">
            <div class="field-group">
              <label for="name">{form.labels.name}</label>
              <input type="text" id="name" name="name" required autocomplete="name" />
            </div>
            <div class="field-group">
              <label for="business">{form.labels.business}</label>
              <input type="text" id="business" name="business" required autocomplete="organization" />
            </div>
          </div>
          <div class="input-row">
            <div class="field-group">
              <label for="whatsapp">{form.labels.whatsapp}</label>
              <input type="tel" id="whatsapp" name="whatsapp" required autocomplete="tel" />
            </div>
            <div class="field-group">
              <label for="email">{form.labels.email}</label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
          </div>

          <div class="field-group products-field">
            <label>{form.labels.products}</label>
            <div class="selection-grid">
              {
                form.products_list &&
                  form.products_list.map((prod: any, index: number) => (
                    <label class="select-btn">
                      <input
                        type="checkbox"
                        name="products"
                        value={prod}
                        checked={index === 0}
                      />
                      <span>{prod}</span>
                    </label>
                  ))
              }
            </div>
          </div>

          <button type="submit" class="submit-btn">
            <span>{form.btn}</span>
            <i class="ri-arrow-right-line"></i>
          </button>
        </form>
      </div>
    </section>

  </div><!-- /distribuidor-container -->

  <script is:inline>
  // ─────────────────────────────────────────────────────────────
  // UTILIDAD: espera a que las libs estén listas (polling seguro)
  // ─────────────────────────────────────────────────────────────
  function waitForLibs(callback, maxWait) {
    var waited = 0;
    var interval = setInterval(function () {
      waited += 50;
      if (typeof window.gsap !== "undefined" && typeof window.ScrollTrigger !== "undefined") {
        clearInterval(interval);
        callback();
      } else if (waited >= (maxWait || 6000)) {
        clearInterval(interval);
        callback(); // intentar igual con lo disponible
      }
    }, 50);
  }

  // ─────────────────────────────────────────────────────────────
  // FUNCIÓN PRINCIPAL
  // ─────────────────────────────────────────────────────────────
  function initDistribuidor() {
    if (typeof window.gsap === "undefined") {
      setTimeout(initDistribuidor, 200);
      return;
    }

    var gsap = window.gsap;
    var ScrollTrigger = window.ScrollTrigger;

    if (ScrollTrigger) {
      gsap.registerPlugin(ScrollTrigger);
      // Limpiar instancias anteriores (SPA/View Transitions de Astro)
      ScrollTrigger.getAll().forEach(function (st) { st.kill(); });
    }

    // ── HERO ─────────────────────────────────────────────────────
    var heroTl = gsap.timeline({ defaults: { ease: "power4.out" } });
    heroTl
      .from(".gs-title", { y: 100, opacity: 0, duration: 1.2 })
      .from(".gs-fade",  { y: 30,  opacity: 0, duration: 0.8, stagger: 0.15 }, "-=0.6")
      .from(".gs-img",   { scale: 0.9, opacity: 0, duration: 1.5, ease: "power2.out" }, "-=1");

    // ── CARDS ─────────────────────────────────────────────────────
    var cards = document.querySelectorAll(".card");
    if (cards.length > 0 && ScrollTrigger) {
      gsap.fromTo(
        cards,
        { y: 80, autoAlpha: 0, scale: 0.95 },
        {
          y: 0, autoAlpha: 1, scale: 1,
          duration: 0.9,
          stagger: { amount: 0.4, from: "start" },
          ease: "back.out(1.4)",
          scrollTrigger: {
            trigger: ".grid-features",
            start: "top 90%",
            toggleActions: "play none none none",
          },
        }
      );
    }

    // ── GS-REVEAL (stats + form)
    // CLAVE FIX VERCEL: detecta si el elemento ya está en viewport al cargar
    // para no depender de scroll en páginas SSG servidas desde CDN
    // ──────────────────────────────────────────────────────────────
    document.querySelectorAll(".gs-reveal").forEach(function (elem) {
      var rect = elem.getBoundingClientRect();
      var alreadyVisible = rect.top < window.innerHeight * 0.98;

      if (alreadyVisible || !ScrollTrigger) {
        // Animar directamente sin esperar scroll
        gsap.fromTo(
          elem,
          { y: 60, autoAlpha: 0 },
          { y: 0, autoAlpha: 1, duration: 1.2, ease: "power3.out", delay: 0.4 }
        );
      } else {
        gsap.fromTo(
          elem,
          { y: 60, autoAlpha: 0 },
          {
            y: 0, autoAlpha: 1, duration: 1.2, ease: "power3.out",
            scrollTrigger: {
              trigger: elem,
              start: "top 95%",
              toggleActions: "play none none none",
            },
          }
        );
      }
    });

    // ── COUNTERS ──────────────────────────────────────────────────
    // FIX VERCEL: si el stat ya está en viewport (page load desde CDN),
    // arrancar la animación directamente con un delay pequeño.
    document.querySelectorAll(".counter").forEach(function (counter) {
      var targetAttr = counter.getAttribute("data-target");
      if (!targetAttr) return;

      var targetValue = parseInt(targetAttr.replace(/\D/g, ""), 10) || 0;
      if (targetValue === 0) return; // nada que animar

      var countObj = { val: 0 };

      var rect = counter.getBoundingClientRect();
      var alreadyVisible = rect.top < window.innerHeight * 0.98;

      // Formateador de números (puntos de miles)
      function formatNum(n) {
        return Math.round(n).toLocaleString("es-MX");
      }

      if (alreadyVisible || !ScrollTrigger) {
        // Ya visible: animar con delay para que se vea después del reveal
        gsap.to(countObj, {
          val: targetValue,
          duration: 2.5,
          delay: 0.8,
          ease: "power2.out",
          onUpdate: function () { counter.textContent = formatNum(countObj.val); },
          onComplete: function () { counter.textContent = formatNum(targetValue); },
        });
      } else {
        gsap.to(countObj, {
          val: targetValue,
          duration: 2.5,
          ease: "power2.out",
          scrollTrigger: {
            trigger: counter,
            start: "top 95%",
            toggleActions: "play none none reset",
          },
          onUpdate: function () { counter.textContent = formatNum(countObj.val); },
          onComplete: function () { counter.textContent = formatNum(targetValue); },
        });
      }
    });

    // ── THREE.JS PARTICLES ───────────────────────────────────────
    if (typeof window.THREE !== "undefined" && window.innerWidth > 768) {
      initThreeJSBackground();
    }

    // ── VANILLA TILT ─────────────────────────────────────────────
    if (typeof window.VanillaTilt !== "undefined") {
      var tiltEls = document.querySelectorAll(".js-tilt");
      if (tiltEls.length) {
        window.VanillaTilt.init(tiltEls, {
          max: 8, speed: 400, glare: true, "max-glare": 0.15, scale: 1.03,
        });
      }
    }

    // ── CAROUSEL DOTS (móvil) ────────────────────────────────────
    setupCarouselDots();

    // ── FORM ─────────────────────────────────────────────────────
    setupFormSubmission();
  }

  // ─────────────────────────────────────────────────────────────
  // THREE.JS BACKGROUND
  // ─────────────────────────────────────────────────────────────
  function initThreeJSBackground() {
    var container = document.getElementById("canvas-bg");
    if (!container) return;
    container.innerHTML = "";

    var scene  = new THREE.Scene();
    var camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 40;

    var renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    var geo       = new THREE.BufferGeometry();
    var count     = 600;
    var positions = new Float32Array(count * 3);
    for (var i = 0; i < count * 3; i++) { positions[i] = (Math.random() - 0.5) * 120; }
    geo.setAttribute("position", new THREE.BufferAttribute(positions, 3));

    var mat = new THREE.PointsMaterial({
      size: 0.15, color: 0xfb670b, transparent: true, opacity: 0.6, sizeAttenuation: true,
    });

    var particles = new THREE.Points(geo, mat);
    scene.add(particles);

    var rafId;
    function animate() {
      if (!document.getElementById("canvas-bg")) { cancelAnimationFrame(rafId); return; }
      rafId = requestAnimationFrame(animate);
      particles.rotation.y += 0.0008;
      particles.rotation.x -= 0.0005;
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener("resize", function () {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  }

  // ─────────────────────────────────────────────────────────────
  // CAROUSEL DOTS
  // ─────────────────────────────────────────────────────────────
  function setupCarouselDots() {
    var grid = document.querySelector(".grid-features");
    var dotsContainer = document.getElementById("cardsDots");
    if (!grid || !dotsContainer) return;

    var cards = grid.querySelectorAll(".card");
    if (!cards.length) return;

    dotsContainer.innerHTML = "";
    cards.forEach(function (_, i) {
      var dot = document.createElement("button");
      dot.className = "carousel-dot" + (i === 0 ? " active" : "");
      dot.setAttribute("aria-label", "Ir a card " + (i + 1));
      dot.addEventListener("click", function () {
        cards[i].scrollIntoView({ behavior: "smooth", inline: "start", block: "nearest" });
      });
      dotsContainer.appendChild(dot);
    });

    grid.addEventListener("scroll", function () {
      var scrollLeft = grid.scrollLeft;
      var cardWidth  = cards[0].offsetWidth + 14; // gap
      var active     = Math.round(scrollLeft / cardWidth);
      dotsContainer.querySelectorAll(".carousel-dot").forEach(function (dot, i) {
        dot.classList.toggle("active", i === active);
      });
    }, { passive: true });
  }

  // ─────────────────────────────────────────────────────────────
  // FORM SUBMISSION
  // ─────────────────────────────────────────────────────────────
  function setupFormSubmission() {
    var formEl = document.getElementById("distribuidor-form");
    var reveal = document.getElementById("revealEffect");
    if (!formEl || !reveal) return;

    // Clonar para eliminar listeners anteriores (evita doble submit en SPA)
    var newForm = formEl.cloneNode(true);
    formEl.parentNode.replaceChild(newForm, formEl);

    newForm.addEventListener("submit", async function (e) {
      e.preventDefault();

      var checked = Array.from(newForm.querySelectorAll('input[name="products"]:checked'))
        .map(function (el) { return el.value; })
        .join(", ");

      var payload = {
        action   : "lead",
        nombre   : newForm.querySelector('[name="name"]').value,
        empresa  : newForm.querySelector('[name="business"]').value,
        whatsapp : newForm.querySelector('[name="whatsapp"]').value,
        email    : newForm.querySelector('[name="email"]').value,
        productos: checked,
      };

      var btn = newForm.querySelector(".submit-btn");
      if (btn) btn.disabled = true;

      try {
        await fetch("/api/analytics", {
          method : "POST",
          headers: { "Content-Type": "application/json" },
          body   : JSON.stringify(payload),
        });
      } catch (err) {
        console.warn("Error guardando lead:", err);
      }

      reveal.classList.add("active");

      setTimeout(function () {
        reveal.classList.remove("active");
        newForm.reset();
        if (btn) btn.disabled = false;
      }, 3500);
    });
  }

  // ─────────────────────────────────────────────────────────────
  // ARRANQUE — compatible con carga normal + SPA (View Transitions)
  // ─────────────────────────────────────────────────────────────
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", function () {
      waitForLibs(initDistribuidor, 6000);
    });
  } else {
    waitForLibs(initDistribuidor, 6000);
  }

  // Astro View Transitions / SPA routing
  document.addEventListener("astro:page-load",  function () { waitForLibs(initDistribuidor, 6000); });
  document.addEventListener("astro:after-swap", function () { waitForLibs(initDistribuidor, 6000); });
  </script>

  <Footer currentLang={currentLang} />
</BaseLayout>