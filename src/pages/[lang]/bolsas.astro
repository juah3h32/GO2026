---
import "../../styles/cuerdas.css";
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import BuyButton from "../../components/BuyButton.astro";
import Footer from "../../components/Footer.astro";
import { languages, translations } from "../../i18n";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = (lang && lang in translations) ? lang : 'es';
const t = translations[currentLang as keyof typeof translations] as any;

const pageData = t.bolsas;
const productsList = pageData.products;
const firstProduct = productsList[0];
const specsLabels = pageData.specs_labels;

const specs = [
  { label: specsLabels.width,  id: "spec-width",  tag: firstProduct.specs_values.width },
  { label: specsLabels.height, id: "spec-height", tag: firstProduct.specs_values.height },
  { label: specsLabels.mat,    id: "spec-mat",    tag: firstProduct.specs_values.mat },
  { label: specsLabels.use,    id: "spec-use",    tag: firstProduct.specs_values.use }
];

const CLOUD = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || 'dfuzfdrat';

const BG_VIDEO = `/videos/bolsas/video.mp4`;
const BG_POSTER = `https://res.cloudinary.com/${CLOUD}/video/upload/f_jpg,q_auto,so_0/GO/bolsas/video.jpg`;
---

<BaseLayout
    title={pageData.meta_title}
    description={pageData.meta_description || ""}
    canonicalSlug="bolsas/"
    currentLang={currentLang}
    moveLogoMobile={true}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={firstProduct.img} fetchpriority="high" />
    <link rel="preload" as="image" href={BG_POSTER} fetchpriority="high" />
  </Fragment>

  <div id="wipe-transition" class="wipe-container"></div>

  <div class="video-bg-wrapper">
    <video
      class="video-bg visible"
      src={BG_VIDEO}
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={BG_POSTER}
    ></video>
    <div class="video-overlay"></div>
  </div>

  <main class="main-container" data-products={JSON.stringify(productsList)}>

    <div class="content">
      <a href={`/${currentLang}/productos`} class="back-arrow-btn2" id="btn-regresar" aria-label={pageData.back_aria}>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
      </a>

      <div class="text-area" style="max-width: 550px; align-items: flex-start;">
        <h1 id="product-title" class="fade-in-text anim-text" style="text-align: left; width: 100%;">
          {firstProduct.name}
        </h1>
        <p id="product-desc" class="fade-in-text anim-text" style="text-align: left; width: 100%; line-height: 1.5;">
          {firstProduct.description}
        </p>

        <div class="specs-container fade-in-text anim-text" style="text-align: left; width: 100%;">
          <h3 class="specs-title">{pageData.specs_title}</h3>
          <div class="specs-grid">
            {specs.map((spec) => (
              <div class="spec-box">
                <span class="spec-label">{spec.label}</span>
                <span class="spec-value" id={spec.id}>{spec.tag}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="fade-in-text w-full flex justify-center lg:justify-start">
          <BuyButton text={t.common.buy || 'Comprar'} redirecting={t.common.redirecting || 'Redirigiendo...'} />
        </div>
      </div>

      <div class="thumbnails fade-in-text" id="thumbnails-container">
        {productsList.map((prod: any, index: number) => (
          <div
            class={`thumb-item ${index === 0 ? 'active' : ''}`}
            data-index={String(index)}
            role="button"
            tabindex="0"
            aria-label={prod.name}
          >
            <img src={prod.thumb} alt={prod.name} loading="lazy" decoding="async" width="60" height="60"/>
          </div>
        ))}
      </div>
    </div>

    <div class="wheel-container">
      <div class="wheel" id="product-wheel" style="position: relative;">

        <div class="product-image-overlay" id="product-image-overlay">
          <img
            id="product-hero-img"
            class="product-hero-img"
            src={firstProduct.img}
            alt={firstProduct.name}
          />
        </div>

        <div class="product-gallery" id="product-gallery">
          {productsList.map((prod: any, index: number) => (
            <div class={`gallery-strip ${index === 0 ? 'active' : ''}`} data-gallery-index={index}>
              {(prod.gallery || [prod.img, prod.img, prod.img]).map((imgSrc: string, imgIdx: number) => (
                <div class="gallery-photo" data-img-index={imgIdx + 1}>
                  <img
                    src={imgSrc}
                    alt={`${prod.name} vista ${imgIdx + 1}`}
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="gallery-photo-glow"></div>
                </div>
              ))}
            </div>
          ))}
        </div>

      </div>
    </div>

  </main>

  <script is:inline>
  function initBolsasLogic() {
    const container = document.querySelector('.main-container');
    if (!container) return;

    const products = JSON.parse(container.dataset.products || '[]');


    const titleEl = document.getElementById('product-title');
    const descEl  = document.getElementById('product-desc');
    const heroImg = document.getElementById('product-hero-img');

    const specIds = {
      width:  document.getElementById('spec-width'),
      height: document.getElementById('spec-height'),
      mat:    document.getElementById('spec-mat'),
      use:    document.getElementById('spec-use'),
    };

    function updateContent(idx) {
      const product = products[idx];
      if (!product) return;
      const anims = document.querySelectorAll('.anim-text');
      const applyText = () => {
        if (titleEl) titleEl.textContent = product.name;
        if (descEl)  descEl.textContent  = product.description;
        if (product.specs_values) {
          if (specIds.width)  specIds.width.textContent  = product.specs_values.width  || '';
          if (specIds.height) specIds.height.textContent = product.specs_values.height || '';
          if (specIds.mat)    specIds.mat.textContent    = product.specs_values.mat    || '';
          if (specIds.use)    specIds.use.textContent    = product.specs_values.use    || '';
        }
      };
      anims.forEach(el => { el.classList.remove('js-animating'); el.style.opacity = '0'; });
      setTimeout(() => {
        applyText();
        anims.forEach(el => { el.style.opacity = ''; el.classList.add('js-animating'); });
        setTimeout(() => anims.forEach(el => el.classList.remove('js-animating')), 350);
      }, 200);
    }

    function updateGallery(idx) {
      document.querySelectorAll('.gallery-strip').forEach((strip, i) => {
        strip.classList.toggle('active', i === idx);
      });
    }

    function selectProduct(idx) {
      const thumbs = document.querySelectorAll('.thumb-item');
      if (thumbs[idx] && thumbs[idx].classList.contains('active')) return;

      thumbs.forEach(t => t.classList.remove('active'));
      if (thumbs[idx]) thumbs[idx].classList.add('active');

      if (heroImg && products[idx] && products[idx].img) {
        heroImg.src = products[idx].img;
        heroImg.alt = products[idx].name || '';
      }

      updateContent(idx);
      updateGallery(idx);
    }

    const thumbs = document.querySelectorAll('.thumb-item');
    thumbs.forEach((thumb) => {
      const idx = parseInt(thumb.dataset.index, 10);
      if (isNaN(idx)) return;

      thumb.addEventListener('touchstart', function(e) {
        e.stopPropagation();
      }, { passive: true });

      thumb.addEventListener('touchend', function(e) {
        e.stopPropagation();
        e.preventDefault();
        selectProduct(idx);
      }, { passive: false });

      thumb.addEventListener('click', function(e) {
        e.stopPropagation();
        selectProduct(idx);
      });

      thumb.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          selectProduct(idx);
        }
      });
    });

    const textArea = document.querySelector('.text-area');
    if (textArea && window.innerWidth <= 1024) {
      let startY = 0, isDragging = false;
      textArea.addEventListener('touchstart', function(e) {
        if (e.target.closest('.thumb-item') || e.target.closest('#thumbnails-container')) return;
        const touch = e.touches[0];
        const rect  = textArea.getBoundingClientRect();
        if (touch.clientY - rect.top > 60) return;
        startY = touch.clientY; isDragging = true;
      }, { passive: true });
      textArea.addEventListener('touchend', function(e) {
        if (e.target.closest('.thumb-item') || e.target.closest('#thumbnails-container')) return;
        if (!isDragging || !startY) return;
        const diff = startY - e.changedTouches[0].clientY;
        if (diff > 40)       textArea.classList.add('expanded');
        else if (diff < -40) textArea.classList.remove('expanded');
        startY = 0; isDragging = false;
      }, { passive: true });
    }

    document.querySelectorAll('.gallery-photo').forEach((photo) => {
      const activate = () => {
        const clickedImg = photo.querySelector('img');
        if (heroImg && clickedImg) heroImg.src = clickedImg.getAttribute('src');
      };
      photo.addEventListener('touchend', function(e) {
        e.stopPropagation(); e.preventDefault(); activate();
      }, { passive: false });
      photo.addEventListener('click', function(e) {
        e.stopPropagation(); activate();
      });
    });

    // Mobile: mostrar solo 5 thumbs + botón "ver más"
    if (window.innerWidth <= 1024) {
      const thumbsContainer = document.getElementById('thumbnails-container');
      if (thumbsContainer) {
        thumbsContainer.querySelector('.thumb-more-btn')?.remove();
        const allThumbs = Array.from(thumbsContainer.querySelectorAll('.thumb-item'));
        const LIMIT = 5;
        if (allThumbs.length > LIMIT) {
          allThumbs.forEach((t, i) => { if (i >= LIMIT) t.classList.add('thumb-mobile-hidden'); });
          const remaining = allThumbs.length - LIMIT;
          const moreBtn = document.createElement('button');
          moreBtn.className = 'thumb-more-btn';
          moreBtn.textContent = '+' + remaining;
          moreBtn.setAttribute('aria-expanded', 'false');
          let expanded = false;
          function toggleMore(e) {
            e.stopPropagation();
            expanded = !expanded;
            allThumbs.forEach((t, i) => {
              if (i >= LIMIT) t.classList.toggle('thumb-mobile-hidden', !expanded);
            });
            moreBtn.textContent = expanded ? '−' : '+' + remaining;
            moreBtn.setAttribute('aria-expanded', String(expanded));
            moreBtn.classList.toggle('is-open', expanded);
          }
          moreBtn.addEventListener('click', toggleMore);
          moreBtn.addEventListener('touchend', function(e) {
            e.preventDefault(); toggleMore(e);
          }, { passive: false });
          thumbsContainer.appendChild(moreBtn);
        }
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBolsasLogic);
  } else {
    initBolsasLogic();
  }
  document.addEventListener("astro:page-load",  initBolsasLogic);
  document.addEventListener("astro:after-swap", initBolsasLogic);
  </script>

  <script is:inline>
  function initTransition() {
    const wipe = document.getElementById("wipe-transition");
    const btn  = document.getElementById("btn-regresar");
    if (!wipe || !btn) return;
    wipe.classList.remove("active");
    const newBtn = btn.cloneNode(true);
    btn.parentNode.replaceChild(newBtn, btn);
    newBtn.addEventListener("click", (e) => {
      e.preventDefault();
      const url = newBtn.getAttribute("href");
      const isDark = document.documentElement.classList.contains('dark') || document.body.classList.contains('dark');
      wipe.style.setProperty('--reveal-bg', isDark ? "#262626" : "#ffffff");
      wipe.classList.add("active");
      setTimeout(() => { window.location.href = url; }, 600);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransition);
  } else {
    initTransition();
  }
  document.addEventListener("astro:page-load",  initTransition);
  document.addEventListener("astro:after-swap", initTransition);
  </script>

  <Footer currentLang={currentLang} />
</BaseLayout>
